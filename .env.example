# Copy to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.
#
# These are also required in Vercel:
#   Project Settings > Environment Variables (all 3 envs: Production, Preview, Development)

BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional. Defaults to https://github.com/thejakeerickson/flash-report
FLASH_REPORT_GITHUB_URL=
