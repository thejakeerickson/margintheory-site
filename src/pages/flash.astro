---
import BaseLayout from '../layouts/BaseLayout.astro';

const SITE_URL = 'https://margintheory.co';

const pageSchema = {
  '@type': 'WebPage',
  '@id': `${SITE_URL}/flash#webpage`,
  name: 'The Flash Report — Free Template',
  description:
    'Free open-source template for the daily flash report I run for fractional CFO clients. Plug in your data, render a clean 2-page PDF.',
};
---
<BaseLayout
  title="The Flash Report. Free template + build guide. | Margin Theory"
  description="Free, open-source template for the daily flash report I run for my fractional CFO clients. Plug in your numbers, render a clean 2-page PDF every morning."
  extraSchemas={[pageSchema]}
  noNav={true}
  conversionPage={true}
  minimalFooter={true}
>
  <div class="max-w-3xl mx-auto px-6 pt-8">
    <a href="/" class="font-bold text-lg tracking-tight text-white">
      Margin Theory
    </a>
  </div>

  <!-- HERO + FORM -->
  <section>
    <div class="max-w-2xl mx-auto px-6 pt-12 pb-20 md:pt-20">
      <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-center mb-5 text-white leading-[1.15]">
        Run your business on <span class="italic text-brand-blue">leading indicators</span>.
      </h1>
      <p class="text-lg md:text-xl text-white/85 text-center mb-10 leading-relaxed">
        Free template plus build guide for the daily flash I built for my fractional CFO clients. Yesterday's cash, sales, and variances. Drop in your email and I'll send you the repo.
      </p>

      <div id="flash-form-card" class="border border-white/15 bg-white/[0.02] p-6 md:p-8">
        <form id="flash-form" class="space-y-3" novalidate>
          <input
            id="flash-email"
            type="email"
            name="email"
            inputmode="email"
            autocomplete="email"
            required
            placeholder="you@yourcompany.com"
            class="w-full px-4 py-3 bg-white text-charcoal text-base rounded-sm border border-transparent focus:outline-none focus:border-brand-blue placeholder:text-charcoal/40"
          />
          <button
            id="flash-submit"
            type="submit"
            class="w-full inline-flex items-center justify-center px-6 py-4 bg-brand-blue text-white text-lg font-bold rounded-sm hover:opacity-90 transition shadow-lg disabled:opacity-60 disabled:cursor-not-allowed"
          >
            Send me the repo
          </button>
          <p id="flash-error" class="text-sm text-red-300 hidden" role="alert"></p>
          <p class="text-xs text-white/50 text-center pt-2">
            You'll also get the Margin Theory newsletter. Unsubscribe anytime.
          </p>
        </form>
      </div>

      <!-- Success state (hidden until subscribe succeeds) -->
      <div id="flash-success" class="hidden border border-brand-blue/40 bg-brand-blue/[0.08] p-6 md:p-8">
        <h2 class="text-xl md:text-2xl font-semibold text-white mb-3">
          You're in. Check your inbox.
        </h2>
        <p class="text-white/85 text-base mb-5 leading-relaxed">
          The welcome email is on its way. If it lands in promotions, move it to primary so the next issue doesn't get lost.
        </p>
        <a
          id="flash-github"
          href="https://github.com/thejakeerickson/flash-report"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center px-6 py-3 bg-brand-blue text-white text-base font-bold rounded-sm hover:opacity-90 transition"
        >
          Open the GitHub repo →
        </a>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('flash-form') as HTMLFormElement;
    const emailInput = document.getElementById('flash-email') as HTMLInputElement;
    const submit = document.getElementById('flash-submit') as HTMLButtonElement;
    const error = document.getElementById('flash-error') as HTMLParagraphElement;
    const card = document.getElementById('flash-form-card') as HTMLDivElement;
    const success = document.getElementById('flash-success') as HTMLDivElement;
    const githubLink = document.getElementById('flash-github') as HTMLAnchorElement;

    function showError(msg: string) {
      error.textContent = msg;
      error.classList.remove('hidden');
    }
    function clearError() {
      error.textContent = '';
      error.classList.add('hidden');
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearError();

      const email = emailInput.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showError('Please enter a valid email address.');
        emailInput.focus();
        return;
      }

      submit.disabled = true;
      submit.textContent = 'Sending...';

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await res.json().catch(() => ({}));

        if (!res.ok) {
          showError(data?.error || 'Something went wrong. Try again or email jake@margintheory.co.');
          submit.disabled = false;
          submit.textContent = 'Send me the repo';
          return;
        }

        if (data?.github_url) {
          githubLink.href = data.github_url;
        }
        card.classList.add('hidden');
        success.classList.remove('hidden');
        success.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } catch (err) {
        showError('Network error. Check your connection and try again.');
        submit.disabled = false;
        submit.textContent = 'Send me the repo';
      }
    });
  </script>
</BaseLayout>
