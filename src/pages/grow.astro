---
import BaseLayout from '../layouts/BaseLayout.astro';

const calendlyUrl = 'https://calendly.com/jake-qmqx/strategy-call';
const loomEmbedUrl = 'https://www.loom.com/embed/ce5ecf60bd1b403e8f5d5114d440352b?hide_owner=true&hide_share=true&hide_title=true&hideEmbedTopBar=true';
const contactEmail = 'jake@margintheory.co';
const SITE_URL = 'https://margintheory.co';

const serviceSchema = {
  '@type': 'Service',
  '@id': `${SITE_URL}/grow#service`,
  name: 'Margin Theory Fractional CFO Engagement',
  serviceType: 'Fractional CFO',
  provider: { '@id': `${SITE_URL}/#organization` },
  areaServed: { '@type': 'Country', name: 'United States' },
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'Owner-operators doing $500K to $20M in annual revenue',
  },
  description:
    'Embedded fractional CFO engagement for owner-operator businesses doing $500K to $20M. Tracks the performance of the business, finds what is leaking, backs every big call with the numbers.',
};
---
<BaseLayout
  title="If you're doing $500K to $20M and making big calls alone, watch this. | Margin Theory"
  description="A short video on how Margin Theory works as the embedded financial operator for owner-operator businesses doing $500K to $20M."
  extraSchemas={[serviceSchema]}
  noNav={true}
  conversionPage={true}
  minimalFooter={true}
>
  <!-- Logo bar — minimal brand presence, no nav -->
  <div class="max-w-3xl mx-auto px-6 pt-8">
    <a href="/" class="font-bold text-lg tracking-tight text-hampton-text">
      Margin Theory
    </a>
  </div>

  <!-- Headline + Video (Hampton off-white section) -->
  <section>
    <div class="max-w-3xl mx-auto px-6 pt-10 pb-6 md:pt-14">
      <h1 class="font-serif text-3xl md:text-5xl font-semibold tracking-tight text-center mb-8 text-hampton-text leading-[1.15]">
        If you're doing $500K to $20M and making <span class="italic text-hampton-tan">big calls alone</span>, watch this.
      </h1>

      {loomEmbedUrl.includes('PLACEHOLDER') ? (
        <div class="aspect-video w-full overflow-hidden border border-hampton-text/15 shadow-md bg-hampton-text/5 flex items-center justify-center">
          <div class="text-center px-6">
            <div class="text-hampton-tan text-5xl mb-4">▶</div>
            <p class="text-hampton-text/70 text-lg font-medium">5-minute video goes here</p>
            <p class="text-hampton-text/50 text-sm mt-2">Replace PLACEHOLDER_VIDEO_ID in grow.astro with the real Loom ID after recording.</p>
          </div>
        </div>
      ) : (
        <div class="aspect-video w-full overflow-hidden border border-hampton-text/15 shadow-md">
          <iframe
            src={loomEmbedUrl}
            frameborder="0"
            webkitallowfullscreen
            mozallowfullscreen
            allowfullscreen
            class="w-full h-full"
            title="How Margin Theory works"
          ></iframe>
        </div>
      )}
    </div>
  </section>

  <!-- CTA Button (Hampton off-white section, deep teal-black CTA) -->
  <section>
    <div class="max-w-3xl mx-auto px-6 pt-2 pb-12 text-center">
      <a
        href={calendlyUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center px-10 py-5 bg-hampton-dark text-hampton-bg text-xl font-bold rounded-sm hover:opacity-90 transition shadow-md border-2 border-hampton-tan"
      >
        Get on my calendar. It's free.
      </a>
    </div>
  </section>

  <!-- What happens after you click — INVERTED dark teal-black section -->
  <section class="bg-hampton-dark text-hampton-bg">
    <div class="max-w-3xl mx-auto px-6 py-14 md:py-16">
      <h2 class="font-serif text-2xl md:text-3xl font-semibold mb-8 text-hampton-khaki">What happens after you click:</h2>

      <ol class="space-y-5 text-hampton-bg">
        <li class="flex gap-4">
          <span class="flex-shrink-0 w-8 h-8 rounded-sm bg-hampton-clay text-hampton-dark font-bold flex items-center justify-center">1</span>
          <p class="text-lg leading-relaxed pt-0.5">Pick a time on my calendar. We hop on Zoom for 30 minutes.</p>
        </li>
        <li class="flex gap-4">
          <span class="flex-shrink-0 w-8 h-8 rounded-sm bg-hampton-clay text-hampton-dark font-bold flex items-center justify-center">2</span>
          <p class="text-lg leading-relaxed pt-0.5">We talk about your business. What you're navigating right now. I ask questions and listen.</p>
        </li>
        <li class="flex gap-4">
          <span class="flex-shrink-0 w-8 h-8 rounded-sm bg-hampton-clay text-hampton-dark font-bold flex items-center justify-center">3</span>
          <p class="text-lg leading-relaxed pt-0.5">By the time we're done, you'll have a clearer read on your situation.</p>
        </li>
        <li class="flex gap-4">
          <span class="flex-shrink-0 w-8 h-8 rounded-sm bg-hampton-clay text-hampton-dark font-bold flex items-center justify-center">4</span>
          <p class="text-lg leading-relaxed pt-0.5">If there's something worth looking into, I'll show you exactly how I'd approach it.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- Repeat CTA — back to off-white -->
  <section>
    <div class="max-w-3xl mx-auto px-6 pt-12 pb-12 text-center">
      <a
        href={calendlyUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center px-10 py-5 bg-hampton-dark text-hampton-bg text-xl font-bold rounded-sm hover:opacity-90 transition shadow-md border-2 border-hampton-tan"
      >
        Get on my calendar. It's free.
      </a>
    </div>
  </section>

  <!-- Got a Question — off-white with border separation -->
  <section class="border-t border-hampton-text/10">
    <div class="max-w-3xl mx-auto px-6 py-12 text-center">
      <p class="text-lg text-hampton-text/85 mb-3">Got a question about your specific situation before booking?</p>
      <p class="text-lg text-hampton-text">
        Email me directly: <a href={`mailto:${contactEmail}`} class="text-hampton-tan font-semibold hover:underline">{contactEmail}</a>
      </p>
      <p class="text-sm text-hampton-text/60 mt-2">I read every one. Usually reply within a day.</p>
    </div>
  </section>
</BaseLayout>
