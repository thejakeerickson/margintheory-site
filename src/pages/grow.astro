---
import BaseLayout from '../layouts/BaseLayout.astro';

const calendlyUrl = 'https://calendly.com/jake-qmqx/strategy-call';
const loomEmbedUrl = 'https://www.loom.com/embed/5da747993bd1458bb5b557845afabfd4?hide_owner=true&hide_share=true&hide_title=true&hideEmbedTopBar=true';
const contactEmail = 'jake@margintheory.co';
const SITE_URL = 'https://margintheory.co';

const serviceSchema = {
  '@type': 'Service',
  '@id': `${SITE_URL}/grow#service`,
  name: 'Margin Theory Fractional CFO Engagement',
  serviceType: 'Fractional CFO',
  provider: { '@id': `${SITE_URL}/#organization` },
  areaServed: { '@type': 'Country', name: 'United States' },
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'Owner-operators doing $500K to $20M in annual revenue',
  },
  description:
    'Embedded fractional CFO engagement for owner-operator businesses doing $500K to $20M. Tracks the performance of the business, finds what is leaking, backs every big call with the numbers.',
};
---
<BaseLayout
  title="If you're doing $500K to $20M and making big calls alone, watch this. | Margin Theory"
  description="A short video on how Margin Theory works as the embedded financial operator for owner-operator businesses doing $500K to $20M."
  extraSchemas={[serviceSchema]}
  noNav={true}
  conversionPage={true}
  minimalFooter={true}
>
  <!-- Logo bar — minimal brand presence, no nav -->
  <div class="max-w-3xl mx-auto px-6 pt-8">
    <a href="/" class="font-bold text-lg tracking-tight text-white">
      Margin Theory
    </a>
  </div>

  <!-- Headline + Video (charcoal section, dominant — brand kit "When in doubt, go darker") -->
  <section>
    <div class="max-w-3xl mx-auto px-6 pt-10 pb-6 md:pt-14">
      <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-center mb-8 text-white leading-[1.15]">
        If you're doing $500K to $20M and making <span class="italic text-brand-blue">big calls alone</span>, watch this.
      </h1>

      {loomEmbedUrl.includes('PLACEHOLDER') ? (
        <div class="aspect-video w-full overflow-hidden border border-white/15 shadow-2xl bg-white/[0.03] flex items-center justify-center">
          <div class="text-center px-6">
            <div class="text-brand-blue text-5xl mb-4">▶</div>
            <p class="text-white/70 text-lg font-medium">5-minute video goes here</p>
            <p class="text-white/40 text-sm mt-2">Replace PLACEHOLDER_VIDEO_ID in grow.astro with the real Loom ID after recording.</p>
          </div>
        </div>
      ) : (
        <div class="aspect-video w-full overflow-hidden border border-white/15 shadow-2xl">
          <iframe
            src={loomEmbedUrl}
            frameborder="0"
            webkitallowfullscreen
            mozallowfullscreen
            allowfullscreen
            class="w-full h-full"
            title="How Margin Theory works"
          ></iframe>
        </div>
      )}
    </div>
  </section>

  <!-- CTA #1 + process clarity line + trust strip ($40M+ social proof) -->
  <section>
    <div class="max-w-3xl mx-auto px-6 pt-2 pb-12 text-center">
      <a
        href={calendlyUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center px-10 py-5 bg-brand-blue text-white text-xl font-bold rounded-sm hover:opacity-90 transition shadow-lg"
      >
        Get on my calendar (it's free)
      </a>
      <p class="text-white/60 text-sm mt-4">30 min on Zoom. You leave with a clearer read on your situation.</p>
      <p class="text-white/85 text-base mt-6">
        <span class="text-brand-blue font-bold">$40M+</span> in client revenue supported
      </p>
    </div>
  </section>

  <!-- Testimonials — From Owner-Operators (1-column stacked, 4 cards, LinkedIn links where available). Placed BEFORE qualifier per top-VSL research: build trust first, then assess fit. -->
  <section class="border-t border-white/10">
    <div class="max-w-3xl mx-auto px-6 py-14 md:py-16">
      <h2 class="text-2xl md:text-3xl font-semibold mb-10 text-white text-center">
        From Owner-Operators
      </h2>
      <div class="space-y-12">

        <!-- Card 1: Dan — video left, quote+name right (desktop); stacked (mobile). No external link — video is the engagement. -->
        <div class="border border-white/15 bg-white/[0.02] grid md:grid-cols-2">
          <div class="bg-black aspect-[9/16] md:aspect-auto md:flex md:items-center md:justify-center">
            <video
              src="/dan-testimonial.mp4"
              poster="/dan-testimonial-poster.jpg"
              width="1080"
              height="1920"
              controls
              preload="metadata"
              playsinline
              webkit-playsinline
              controlsList="nodownload"
              class="block w-full h-full object-cover md:w-auto md:h-auto md:max-h-[560px] md:mx-auto md:object-contain"
            ></video>
          </div>
          <div class="p-6 md:p-8 flex flex-col justify-center">
            <p class="text-white/90 text-lg md:text-xl leading-relaxed mb-6 italic">
              "He's been able to help me understand things that I had no idea I even needed to understand."
            </p>
            <div>
              <p class="text-white font-bold">Dan</p>
              <p class="text-white/60 text-sm mt-1">Construction owner, $9M+ revenue</p>
            </div>
          </div>
        </div>

        <!-- Card 2: Restaurant client — links to LinkedIn post. Hover state for "alive" feel. -->
        <a
          href="https://www.linkedin.com/posts/realjakeerickson_how-my-client-went-from-302-to-133-profit-share-7430611036648603648-ylvF"
          target="_blank"
          rel="noopener"
          class="block border border-white/15 bg-white/[0.02] hover:border-brand-blue/50 hover:bg-white/[0.04] transition-colors group"
        >
          <img
            src="/restaurant-client-skool.png"
            alt="Restaurant client Skool message: profit margin went from -3.02% to 13.3%"
            class="block w-full h-auto"
          />
          <div class="p-6 border-t border-white/10">
            <p class="text-white/90 text-lg leading-relaxed mb-4 italic">
              "Just having a better understanding of the numbers boosts confidence."
            </p>
            <div class="flex items-end justify-between gap-4">
              <div>
                <p class="text-white font-bold">Restaurant client</p>
                <p class="text-white/60 text-sm mt-1">-3.02% → 13.3% profit margin</p>
              </div>
              <p class="text-brand-blue text-sm font-semibold opacity-70 group-hover:opacity-100 transition flex-shrink-0">
                View on LinkedIn →
              </p>
            </div>
          </div>
        </a>

        <!-- Card 3: Caleb — links to LinkedIn post. Portrait screenshot. -->
        <a
          href="https://www.linkedin.com/posts/realjakeerickson_caleb-went-from-running-a-2m-business-to-share-7442562092886335488-TgXr"
          target="_blank"
          rel="noopener"
          class="block border border-white/15 bg-white/[0.02] hover:border-brand-blue/50 hover:bg-white/[0.04] transition-colors group"
        >
          <img
            src="/caleb-linkedin-post.png"
            alt="Caleb LinkedIn post: went from running a $2M business to an $8M business after building financial visibility"
            class="block w-full h-auto mx-auto max-w-md"
          />
          <div class="p-6 border-t border-white/10">
            <p class="text-white/90 text-lg leading-relaxed mb-4 italic">
              "Do yourself a favor and get a sit down with Jake."
            </p>
            <div class="flex items-end justify-between gap-4">
              <div>
                <p class="text-white font-bold">Caleb</p>
                <p class="text-white/60 text-sm mt-1">$2M → $8M business</p>
              </div>
              <p class="text-brand-blue text-sm font-semibold opacity-70 group-hover:opacity-100 transition flex-shrink-0">
                View on LinkedIn →
              </p>
            </div>
          </div>
        </a>

        <!-- Card 4: Mark Annabelli — Google review screenshot. No external link (no LinkedIn post for this one). -->
        <div class="border border-white/15 bg-white/[0.02]">
          <img
            src="/mark-google-review.png"
            alt="Mark Annabelli 5-star Google review"
            class="block w-full h-auto"
          />
          <div class="p-6 border-t border-white/10">
            <p class="text-white/90 text-lg leading-relaxed mb-4 italic">
              "Eye-opening and have given us great hope for our company's future."
            </p>
            <div>
              <p class="text-white font-bold">Mark Annabelli</p>
              <p class="text-white/60 text-sm mt-1">5-star Google review</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA #2 between testimonials and qualifier — gives natural conversion break after the 4 proof cards land, before the "is this for me?" assessment -->
  <section>
    <div class="max-w-3xl mx-auto px-6 pt-12 pb-12 text-center">
      <a
        href={calendlyUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center px-10 py-5 bg-brand-blue text-white text-xl font-bold rounded-sm hover:opacity-90 transition shadow-lg"
      >
        Get on my calendar (it's free)
      </a>
      <p class="text-white/60 text-sm mt-4">30 min on Zoom. You leave with a clearer read on your situation.</p>
    </div>
  </section>

  <!-- Does this apply to your business? — INVERTED soft-gray, qualifier as visual centerpiece + disqualifier + inline CTA. Placed AFTER testimonials so prospect has seen who else it applied to before assessing fit. -->
  <section class="bg-soft-gray text-charcoal">
    <div class="max-w-3xl mx-auto px-6 py-14 md:py-16">
      <h2 class="text-2xl md:text-3xl font-semibold mb-6 text-charcoal text-center">
        Does this apply to your business?
      </h2>
      <p class="text-2xl text-brand-blue font-semibold mb-8 text-center">
        Yes, the vertical doesn't matter.
      </p>
      <div class="space-y-4 text-lg text-charcoal/85 leading-relaxed">
        <p>Every owner doing $500K to $20M is making the same calls. Hire. Price. Invest in a project. Or figure out whether to expand.</p>
        <p>The math underneath it is the same whether you're running a <span class="text-charcoal font-bold">service</span>, selling a <span class="text-charcoal font-bold">product</span>, or in the <span class="text-charcoal font-bold">trades</span>.</p>
        <p class="text-charcoal font-semibold">That's where I work.</p>
      </div>
      <p class="text-charcoal/60 text-base italic mt-6">
        Not your guy if you're under $500K, looking for a tax accountant, or chasing venture-scale growth.
      </p>
      <div class="text-center mt-10">
        <a
          href={calendlyUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center px-10 py-5 bg-brand-blue text-white text-xl font-bold rounded-sm hover:opacity-90 transition shadow-lg"
        >
          Get on my calendar (it's free)
        </a>
        <p class="text-charcoal/60 text-sm mt-4">30 min on Zoom. You leave with a clearer read on your situation.</p>
      </div>
    </div>
  </section>

  <!-- Got a Question — charcoal with subtle border -->
  <section class="border-t border-white/10">
    <div class="max-w-3xl mx-auto px-6 py-12 text-center">
      <p class="text-lg text-white/85 mb-3">Got a question about your specific situation before booking?</p>
      <p class="text-lg text-white">
        Email me directly: <a href={`mailto:${contactEmail}`} class="text-brand-blue font-semibold hover:underline">{contactEmail}</a>
      </p>
      <p class="text-sm text-white/60 mt-2">I read every one. Usually reply within a day.</p>
    </div>
  </section>
</BaseLayout>
