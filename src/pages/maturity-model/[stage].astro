---
import BaseLayout from '../../layouts/BaseLayout.astro';

// getStaticPaths is hoisted, so it carries everything it needs. The ten-stage
// ladder (names + map lines) lives here; the full per-stage read is loaded from
// JSON synced out of the PCD source of truth (scripts/maturity_model/sync_web.py).
export function getStaticPaths() {
  const STAGES = [
    { slug: 'foundation',  n: 0, name: 'Foundation',  line: 'just an idea',           emp: 'Just you',       rev: 'Pre-revenue' },
    { slug: 'validation',  n: 1, name: 'Validation',  line: 'the first sale',         emp: 'Just you',       rev: 'Under $100K' },
    { slug: 'traction',    n: 2, name: 'Traction',    line: 'steady customers',       emp: 'You + vendors',  rev: '$100K-$500K' },
    { slug: 'structure',   n: 3, name: 'Structure',   line: 'your first hires',       emp: '2-4 people',     rev: '$500K-$1M' },
    { slug: 'focus',       n: 4, name: 'Focus',       line: 'getting specific',       emp: '5-9 people',     rev: '$1M-$3M' },
    { slug: 'expansion',   n: 5, name: 'Expansion',   line: 'a second offer',         emp: '10-19 people',   rev: '$3M-$10M' },
    { slug: 'efficiency',  n: 6, name: 'Efficiency',  line: 'grow by doing it better', emp: '20-49 people',  rev: '$10M-$30M' },
    { slug: 'systems',     n: 7, name: 'Systems',     line: 'run it on systems',      emp: '50-99 people',   rev: '$30M-$75M' },
    { slug: 'division',    n: 8, name: 'Division',    line: 'specialist teams',       emp: '100-249 people', rev: '$75M-$150M' },
    { slug: 'reinvention', n: 9, name: 'Reinvention', line: 'the next bet',           emp: '250-500 people', rev: '$150M+' },
  ];
  const mods = import.meta.glob('../../data/maturity/*.json', { eager: true });
  const bySlug = {};
  for (const p in mods) { const d = mods[p].default; bySlug[String(d.name).toLowerCase()] = d; }
  const ICP = ['focus', 'expansion', 'efficiency'];
  return STAGES.map((s, i) => ({
    params: { stage: s.slug },
    props: { stage: s, stages: STAGES, data: bySlug[s.slug] ?? null, next: STAGES[i + 1] ?? null, isICP: ICP.includes(s.slug) },
  }));
}

const { stage, stages, data, next, isICP } = Astro.props;
const startHere = data?._start_here ?? [];
const builtOn = data?.built_on ?? [];
const title = data ? `${data.name} | The Business Maturity Model` : `${stage.name} | The Business Maturity Model`;
const desc = data ? `Your business is at the ${data.name} stage. ${data.tagline}` : `The ${stage.name} stage of The Business Maturity Model.`;
---
<BaseLayout title={title} description={desc} noNav={true} conversionPage={true} minimalFooter={true} noindex={true}>
  <div class="bg-paper text-charcoal min-h-screen font-sans">
    <!-- MASTHEAD -->
    <div class="max-w-3xl mx-auto px-6 pt-8">
      <div class="flex items-center justify-between pb-3 border-b-2 border-charcoal">
        <a href="/" class="font-bold tracking-tight text-charcoal text-lg">Margin Theory</a>
        <span class="text-[11px] font-semibold tracking-[0.16em] uppercase text-charcoal/55">The Business Maturity Model</span>
      </div>
    </div>

    {data ? (
      <article>
        <!-- HERO -->
        <section class="max-w-3xl mx-auto px-6 pt-12 pb-12">
          <div class="text-xs font-semibold tracking-[0.18em] uppercase text-brand-blue mb-5">Stage 0{data.stage} / {data.name}</div>
          <h1 class="font-bold text-[1.7rem] md:text-[2.1rem] leading-[1.13] tracking-tight text-charcoal max-w-[24ch] mb-6">{data.tagline}</h1>
          {data.stats && (
            <div class="flex gap-12 pt-6 border-t border-charcoal/10">
              <div>
                <div class="font-bold text-2xl text-charcoal">{data.stats.headcount}</div>
                <div class="text-[11px] font-medium tracking-[0.13em] uppercase text-mid-gray mt-1">Your team</div>
              </div>
              <div>
                <div class="font-bold text-2xl text-charcoal">{data.stats.revenue}</div>
                <div class="text-[11px] font-medium tracking-[0.13em] uppercase text-mid-gray mt-1">Revenue</div>
              </div>
            </div>
          )}
          <a href={`/maturity-model/${stage.slug}.pdf`} download={`The Business Maturity Model - ${data.name}.pdf`}
            class="inline-flex items-center gap-2 mt-8 px-5 py-2.5 border border-charcoal/25 text-charcoal/80 text-sm font-semibold rounded-sm hover:bg-charcoal/[0.04] transition">
            Download this as a PDF
          </a>
        </section>

        <!-- YOU ARE HERE -->
        <section class="max-w-3xl mx-auto px-6 py-10 border-t border-charcoal/10">
          <h2 class="font-bold text-2xl text-charcoal mb-2">You are here.</h2>
          <p class="text-charcoal/55 mb-6 max-w-2xl">Every business climbs the same ten stages, set by how many people you've got and how much you make. You're at {data.name}.</p>
          <div>
            {stages.map((s) => (
              <div class={`flex items-center gap-4 py-3 border-b border-charcoal/10 ${s.n === data.stage ? 'bg-brand-blue/[0.06] -mx-3 px-3 border-b-0 rounded-sm' : ''}`}>
                <span class={`w-7 shrink-0 font-bold ${s.n === data.stage ? 'text-brand-blue' : 'text-charcoal/25'}`}>{s.n}</span>
                <span class={`font-semibold ${s.n === data.stage ? 'text-charcoal' : 'text-charcoal/40'}`}>{s.name}{s.n === data.stage && <span class="ml-2 text-[10px] font-bold uppercase tracking-[0.1em] text-brand-blue">you are here</span>}</span>
                <span class={`ml-auto text-sm text-right whitespace-nowrap ${s.n === data.stage ? 'text-brand-blue font-semibold' : 'text-charcoal/35'}`}>{s.emp} &middot; {s.rev}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- SNAPSHOT -->
        <section class="max-w-3xl mx-auto px-6 py-10 border-t border-charcoal/10">
          <h2 class="font-bold text-2xl text-charcoal mb-5">The snapshot</h2>
          <div>
            <div class="grid grid-cols-[110px_1fr] md:grid-cols-[150px_1fr] gap-5 py-4 border-t border-charcoal/10">
              <div class="text-[11px] font-semibold tracking-[0.12em] uppercase text-mid-gray pt-0.5">Who</div>
              <div class="text-charcoal/80 leading-snug">{data.snapshot.who}</div>
            </div>
            <div class="grid grid-cols-[110px_1fr] md:grid-cols-[150px_1fr] gap-5 py-4 border-t border-charcoal/10">
              <div class="text-[11px] font-semibold tracking-[0.12em] uppercase text-mid-gray pt-0.5">The constraint</div>
              <div class="text-charcoal/80 leading-snug">{data.snapshot.constraint}</div>
            </div>
            <div class="grid grid-cols-[110px_1fr] md:grid-cols-[150px_1fr] gap-5 py-4 border-t border-charcoal/10">
              <div class="text-[11px] font-semibold tracking-[0.12em] uppercase text-mid-gray pt-0.5">Graduate by</div>
              <div class="text-charcoal/80 leading-snug">{data.snapshot.graduate_by}</div>
            </div>
          </div>
        </section>

        <!-- BIG PICTURE + THESIS -->
        <section class="max-w-3xl mx-auto px-6 py-10 border-t border-charcoal/10">
          <div class="text-[11px] font-semibold tracking-[0.13em] uppercase text-mid-gray mb-4">The big picture</div>
          {data.big_picture.map((p, i) => (
            <p class={`text-charcoal/80 leading-relaxed mb-4 max-w-2xl ${i === 0 ? 'first-letter:float-left first-letter:text-[3.1rem] first-letter:leading-[0.78] first-letter:pr-2 first-letter:pt-1 first-letter:font-semibold first-letter:text-charcoal' : ''}`}>{p}</p>
          ))}
          <blockquote class="italic text-xl md:text-2xl text-charcoal leading-snug border-l-[3px] border-brand-blue pl-5 mt-7 max-w-2xl">{data.thesis}</blockquote>
        </section>

        <!-- ACROSS YOUR BUSINESS -->
        <section class="max-w-3xl mx-auto px-6 py-10 border-t border-charcoal/10">
          <h2 class="font-bold text-2xl text-charcoal mb-2">Across your business.</h2>
          <p class="text-charcoal/55 mb-7 max-w-2xl">{data.overview_intro}</p>
          <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-x-5 gap-y-7">
            {data.functions.map((fn) => (
              <div>
                <div class="text-[11px] font-semibold tracking-[0.13em] uppercase text-brand-blue border-b border-charcoal/15 pb-2 mb-3">{fn.name}</div>
                <div class="flex flex-col gap-3">
                  {fn.departments.map((d) => (
                    <div class={`rounded-sm p-3.5 ${d.start_here ? 'bg-brand-blue/[0.07] border border-brand-blue/30' : 'bg-white border border-charcoal/10'}`}>
                      <div class="flex items-center gap-2 flex-wrap mb-1.5">
                        <span class={`font-bold text-[15px] leading-tight ${d.start_here ? 'text-brand-blue' : 'text-charcoal'}`}>{d.name}</span>
                        {d.start_here && <span class="text-[8px] font-bold tracking-[0.1em] uppercase bg-brand-blue text-white px-1.5 py-0.5 rounded">Start here</span>}
                      </div>
                      <div class="text-[13px] text-charcoal/65 leading-snug">{d.start_here ? d.tell : d.constraint}</div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- START HERE -->
        <section class="max-w-3xl mx-auto px-6 py-10 border-t border-charcoal/10">
          <h2 class="font-bold text-2xl text-charcoal mb-2">Start here.</h2>
          <p class="text-charcoal/55 mb-8 max-w-2xl">The one part breaking each engine. Get these right and the rest of the stage gets easier.</p>
          {startHere.map((d, i) => (
            <div class={`py-7 ${i > 0 ? 'border-t border-charcoal/12' : ''}`}>
              <div class="flex items-baseline gap-3 flex-wrap mb-2.5">
                <span class="text-[2.5rem] font-extrabold leading-none tracking-tight text-brand-blue">{String(i + 1).padStart(2, '0')}</span>
                <span class="text-lg font-bold text-charcoal">{d.name}</span>
                <span class="text-[10px] font-semibold tracking-[0.12em] uppercase text-mid-gray">{d.function}</span>
              </div>
              <p class="text-xl md:text-2xl font-bold leading-tight tracking-tight text-charcoal mb-4 max-w-[32ch]">{d.tell}</p>
              <div class="text-[10px] font-semibold tracking-[0.12em] uppercase text-mid-gray mb-1">The problem</div>
              <p class="text-[15px] text-charcoal/65 leading-relaxed mb-4 max-w-2xl">{d.constraint}</p>
              {d.benchmark && (
                <div class="border border-charcoal/10 bg-white px-4 py-3 mb-4 max-w-2xl rounded-sm">
                  <div class="text-[10px] font-semibold tracking-[0.13em] uppercase text-brand-blue mb-1">Benchmark</div>
                  <p class="text-charcoal/80 leading-snug text-[14px]">{d.benchmark}</p>
                </div>
              )}
              <div class="text-[10px] font-semibold tracking-[0.12em] uppercase text-brand-blue mb-1.5">Do this</div>
              <p class="text-[15px] text-charcoal/85 leading-relaxed bg-brand-blue/[0.05] border-l-[3px] border-brand-blue px-4 py-3 max-w-2xl rounded-r-sm">{d.do_this}</p>
              {(d.sources ?? []).map((s) => (
                <div class="inline-flex items-baseline gap-2 bg-brand-blue/[0.08] border-l-2 border-brand-blue px-3 py-1.5 mt-3 mr-2 rounded-r-sm">
                  <span class="text-[9px] font-bold tracking-[0.12em] uppercase text-brand-blue">Source</span>
                  <span class="text-xs text-charcoal/70"><b class="text-charcoal font-semibold">{s.concept}</b> &middot; <i>{s.book}</i>, {s.author}</span>
                </div>
              ))}
            </div>
          ))}
        </section>

        <!-- THE REST -->
        <section class="max-w-3xl mx-auto px-6 py-10 border-t border-charcoal/10">
          <h2 class="font-bold text-2xl text-charcoal mb-2">The rest of your business.</h2>
          <p class="text-charcoal/55 mb-7 max-w-2xl">Not the three to start with, but they're in play at this stage. Here's the move on each, for when you're ready.</p>
          <div class="grid sm:grid-cols-2 gap-x-8 gap-y-6">
            {data.functions.flatMap((fn) =>
              fn.departments.filter((d) => !d.start_here).map((d) => (
                <div class="border-t border-charcoal/10 pt-3">
                  <div class="flex items-baseline gap-2 flex-wrap mb-1">
                    <span class="font-bold text-[15px] text-charcoal">{d.name}</span>
                    <span class="text-[9px] font-semibold tracking-[0.1em] uppercase text-mid-gray">{fn.name}</span>
                  </div>
                  <div class="italic text-charcoal/55 text-[13px] mb-1">{d.constraint}</div>
                  {d.do_this && <p class="text-charcoal/75 text-[13px] leading-relaxed">{d.do_this}</p>}
                  {(d.sources ?? []).map((s) => <div class="text-[11px] text-charcoal/40 italic mt-1">{s.concept} &middot; {s.book}</div>)}
                </div>
              ))
            )}
          </div>
        </section>

        <!-- CTA + BUILT ON -->
        <section class="max-w-3xl mx-auto px-6 py-10 border-t border-charcoal/10">
          {isICP ? (
            <div class="bg-charcoal text-white rounded-sm p-7 md:p-9">
              <div class="font-bold text-2xl text-white mb-3 max-w-[26ch]">{data.cta.headline}</div>
              <p class="text-white/80 leading-relaxed mb-6 max-w-2xl">{data.cta.body}</p>
              <a href="https://calendly.com/jake-qmqx/strategy-call" target="_blank" rel="noopener" class="inline-flex items-center justify-center px-6 py-3 bg-brand-blue text-white text-base font-bold rounded-sm hover:opacity-90 transition">Book a call</a>
            </div>
          ) : (
            <div class="border border-charcoal/15 bg-white rounded-sm p-7 md:p-9">
              <div class="font-bold text-2xl text-charcoal mb-3">Want the next move sent to you?</div>
              <p class="text-charcoal/75 leading-relaxed mb-6 max-w-2xl">{data.cta.body}</p>
              <a href="/flash" class="inline-flex items-center justify-center px-6 py-3 bg-charcoal text-white text-base font-semibold rounded-sm hover:opacity-90 transition">Get the guide</a>
            </div>
          )}

          {builtOn.length > 0 && (
            <div class="mt-8 border-l-[3px] border-brand-blue bg-brand-blue/[0.04] p-5">
              <div class="text-[10px] font-semibold tracking-[0.15em] uppercase text-mid-gray mb-2">Built on</div>
              <div class="text-sm text-charcoal/65 leading-relaxed">This stage draws on {builtOn.map((b, i) => (
                <span><b class="text-charcoal">{b.book}</b> ({b.author}){i < builtOn.length - 1 ? (i === builtOn.length - 2 ? ', and ' : ', ') : ''}</span>
              ))}. The moves are ours. The thinking stands on theirs.</div>
            </div>
          )}

          {next && (
            <p class="mt-10 text-sm text-charcoal/45">Next stage: <span class="text-charcoal/70 font-medium">{next.name}</span> &middot; {next.line}</p>
          )}
          <p class="mt-4"><a href="/maturity-model" class="text-sm text-charcoal/45 hover:text-charcoal transition">&larr; Start over</a></p>
        </section>
      </article>
    ) : (
      <section class="max-w-3xl mx-auto px-6 pt-12 pb-24">
        <div class="text-xs font-semibold tracking-[0.18em] uppercase text-brand-blue mb-4">Stage 0{stage.n} / {stage.name}</div>
        <h1 class="font-bold text-3xl md:text-5xl tracking-tight text-charcoal leading-[1.1] mb-3">{stage.name}</h1>
        <p class="text-lg text-charcoal/70 mb-10 max-w-2xl">The full read for this stage is being written.</p>
        {next && <p class="text-sm text-charcoal/45">Next stage: <span class="text-charcoal/70 font-medium">{next.name}</span></p>}
        <p class="mt-8"><a href="/maturity-model" class="text-sm text-charcoal/45 hover:text-charcoal transition">&larr; Start over</a></p>
      </section>
    )}
  </div>
</BaseLayout>
