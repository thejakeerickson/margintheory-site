---
import BaseLayout from '../../layouts/BaseLayout.astro';

// getStaticPaths is hoisted, so it carries everything it needs. The ten-stage
// ladder (names + map lines) lives here; the full per-stage read is loaded from
// JSON synced out of the PCD source of truth (scripts/maturity_model/sync_web.py).
export function getStaticPaths() {
  const STAGES = [
    { slug: 'foundation',  n: 0, name: 'Foundation',  line: 'just an idea',           emp: 'Just you',       rev: 'Pre-revenue' },
    { slug: 'validation',  n: 1, name: 'Validation',  line: 'the first sale',         emp: 'Just you',       rev: 'Under $100K' },
    { slug: 'traction',    n: 2, name: 'Traction',    line: 'steady customers',       emp: 'You + vendors',  rev: '$100K-$500K' },
    { slug: 'structure',   n: 3, name: 'Structure',   line: 'your first hires',       emp: '2-4 people',     rev: '$500K-$1M' },
    { slug: 'focus',       n: 4, name: 'Focus',       line: 'getting specific',       emp: '5-9 people',     rev: '$1M-$3M' },
    { slug: 'expansion',   n: 5, name: 'Expansion',   line: 'a second offer',         emp: '10-19 people',   rev: '$3M-$10M' },
    { slug: 'efficiency',  n: 6, name: 'Efficiency',  line: 'grow by doing it better', emp: '20-49 people',  rev: '$10M-$30M' },
    { slug: 'systems',     n: 7, name: 'Systems',     line: 'run it on systems',      emp: '50-99 people',   rev: '$30M-$75M' },
    { slug: 'division',    n: 8, name: 'Division',    line: 'specialist teams',       emp: '100-249 people', rev: '$75M-$150M' },
    { slug: 'reinvention', n: 9, name: 'Reinvention', line: 'the next bet',           emp: '250-500 people', rev: '$150M+' },
  ];
  const mods = import.meta.glob('../../data/maturity/*.json', { eager: true });
  const bySlug = {};
  for (const p in mods) { const d = mods[p].default; bySlug[String(d.name).toLowerCase()] = d; }
  const ICP = ['focus', 'expansion', 'efficiency'];
  return STAGES.map((s, i) => ({
    params: { stage: s.slug },
    props: { stage: s, stages: STAGES, data: bySlug[s.slug] ?? null, next: STAGES[i + 1] ?? null, isICP: ICP.includes(s.slug) },
  }));
}

const { stage, stages, data, next, isICP } = Astro.props;
const startHere = data?._start_here ?? [];
const builtOn = data?.built_on ?? [];
const title = data ? `${data.name} | The Business Maturity Model` : `${stage.name} | The Business Maturity Model`;
const desc = data ? `Your business is at the ${data.name} stage. ${data.tagline}` : `The ${stage.name} stage of The Business Maturity Model.`;
---
<BaseLayout title={title} description={desc} noNav={true} conversionPage={true} minimalFooter={true} noindex={true}>
  <div class="max-w-3xl mx-auto px-6 pt-8">
    <a href="/" class="font-bold text-lg tracking-tight text-white">Margin Theory</a>
  </div>

  {data ? (
    <article>
      <!-- HERO -->
      <section class="max-w-3xl mx-auto px-6 pt-10 pb-12">
        <div class="text-xs font-bold tracking-[0.2em] uppercase text-brand-blue mb-3">The Business Maturity Model &middot; Stage {data.stage}</div>
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white leading-[1.0] mb-4">{data.name}</h1>
        <p class="text-lg md:text-xl text-white/75 leading-relaxed max-w-2xl mb-5">{data.tagline}</p>
        {data.stats && (
          <div class="text-xs font-bold tracking-[0.18em] uppercase text-brand-blue">{data.stats.headcount} &middot; {data.stats.revenue} revenue</div>
        )}
        <a href={`/maturity-model/${stage.slug}.pdf`} download={`The Business Maturity Model - ${data.name}.pdf`}
          class="inline-flex items-center gap-2 mt-7 px-5 py-2.5 border border-white/20 bg-white/[0.04] text-white/90 text-sm font-semibold rounded-sm hover:bg-white/10 transition">
          Download this as a PDF
        </a>
      </section>

      <!-- YOU ARE HERE -->
      <section class="max-w-3xl mx-auto px-6 py-10 border-t border-white/10">
        <h2 class="text-2xl font-bold text-white mb-2">You are here.</h2>
        <p class="text-white/60 mb-6 max-w-2xl">Every business climbs the same ten stages, set by how many people you've got and how much you make. You're at {data.name}.</p>
        <div>
          {stages.map((s) => (
            <div class={`flex items-center gap-4 py-3 border-b border-white/10 ${s.n === data.stage ? 'bg-white/[0.05] -mx-3 px-3 border-b-0 rounded-sm' : ''}`}>
              <span class={`w-7 shrink-0 font-extrabold ${s.n === data.stage ? 'text-brand-blue' : 'text-white/25'}`}>{s.n}</span>
              <span class={`font-bold ${s.n === data.stage ? 'text-white' : 'text-white/40'}`}>{s.name}{s.n === data.stage && <span class="ml-2 text-[10px] font-bold uppercase tracking-[0.1em] text-brand-blue">you are here</span>}</span>
              <span class={`ml-auto text-sm text-right whitespace-nowrap ${s.n === data.stage ? 'text-brand-blue font-semibold' : 'text-white/35'}`}>{s.emp} &middot; {s.rev}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- SNAPSHOT -->
      <section class="max-w-3xl mx-auto px-6 py-10 border-t border-white/10">
        <div class="grid md:grid-cols-3 gap-4">
          <div class="border-l-2 border-brand-blue bg-white/[0.03] p-5">
            <div class="text-[10px] font-bold tracking-[0.12em] uppercase text-white/40 mb-2">Who</div>
            <div class="text-white/85 leading-snug">{data.snapshot.who}</div>
          </div>
          <div class="border-l-2 border-brand-blue bg-white/[0.03] p-5">
            <div class="text-[10px] font-bold tracking-[0.12em] uppercase text-white/40 mb-2">The constraint</div>
            <div class="text-white/85 leading-snug">{data.snapshot.constraint}</div>
          </div>
          <div class="border-l-2 border-brand-blue bg-white/[0.03] p-5">
            <div class="text-[10px] font-bold tracking-[0.12em] uppercase text-white/40 mb-2">Graduate by</div>
            <div class="text-white/85 leading-snug">{data.snapshot.graduate_by}</div>
          </div>
        </div>
      </section>

      <!-- BIG PICTURE + THESIS -->
      <section class="max-w-3xl mx-auto px-6 py-10 border-t border-white/10">
        <div class="text-[10px] font-bold tracking-[0.12em] uppercase text-white/40 mb-3">The big picture</div>
        {data.big_picture.map((p) => <p class="text-white/75 leading-relaxed mb-4 max-w-2xl">{p}</p>)}
        <div class="border-l-2 border-brand-blue pl-5 mt-7 text-lg md:text-xl font-semibold text-white max-w-2xl leading-snug">{data.thesis}</div>
      </section>

      <!-- ACROSS YOUR BUSINESS -->
      <section class="max-w-3xl mx-auto px-6 py-10 border-t border-white/10">
        <h2 class="text-2xl font-bold text-white mb-2">Across your business.</h2>
        <p class="text-white/60 mb-7 max-w-2xl">{data.overview_intro}</p>
        {data.functions.map((fn) => (
          <div class="mb-7">
            <div class="text-xs font-bold tracking-[0.14em] uppercase text-brand-blue border-b-2 border-brand-blue/50 pb-2 mb-1">{fn.name}</div>
            {fn.departments.map((d) => (
              <div class={`py-3 ${d.start_here ? 'border-l-2 border-brand-blue bg-brand-blue/[0.07] -mx-3 px-3 rounded-sm' : 'border-b border-white/10'}`}>
                <div class="flex items-center gap-3 flex-wrap">
                  <span class={`font-bold ${d.start_here ? 'text-brand-blue' : 'text-white'}`}>{d.name}</span>
                  {d.start_here && <span class="text-[8px] font-extrabold tracking-[0.1em] uppercase bg-brand-blue text-white px-1.5 py-0.5 rounded">Start here</span>}
                </div>
                <div class="text-sm text-white/65 mt-1">{d.constraint}{(d.sources ?? []).map((s) => <span class="text-white/35 italic"> &middot; {s.concept} ({s.book})</span>)}</div>
              </div>
            ))}
          </div>
        ))}
      </section>

      <!-- START HERE -->
      <section class="max-w-3xl mx-auto px-6 py-10 border-t border-white/10">
        <h2 class="text-2xl font-bold text-white mb-2">Start here.</h2>
        <p class="text-white/60 mb-8 max-w-2xl">The one part breaking each engine. Get these right and the rest of the stage gets easier.</p>
        {startHere.map((d) => (
          <div class="mb-9">
            <div class="flex items-baseline gap-3 mb-1 flex-wrap">
              <span class="text-xl font-bold text-white">{d.name}</span>
              <span class="text-[10px] font-bold tracking-[0.12em] uppercase text-white/35">{d.function}</span>
            </div>
            <div class="italic text-white/55 mb-4">{d.tell}</div>
            <div class="text-[10px] font-bold tracking-[0.12em] uppercase text-red-300/70 mb-1">The constraint</div>
            <p class="text-white/75 leading-relaxed mb-4 max-w-2xl">{d.constraint}</p>
            {d.benchmark && (
              <div class="mb-4">
                <div class="text-[10px] font-bold tracking-[0.12em] uppercase text-green-300/80 mb-1">Benchmark</div>
                <p class="text-white/75 leading-relaxed max-w-2xl">{d.benchmark}</p>
              </div>
            )}
            <div class="text-[10px] font-bold tracking-[0.12em] uppercase text-brand-blue mb-1">Do this</div>
            <p class="text-white/85 leading-relaxed mb-4 max-w-2xl">{d.do_this}</p>
            {(d.sources ?? []).map((s) => (
              <div class="inline-flex items-baseline gap-2 bg-brand-blue/[0.1] border-l-2 border-brand-blue px-3 py-1.5 mr-2 mb-2 rounded-r-sm">
                <span class="text-[9px] font-extrabold tracking-[0.12em] uppercase text-brand-blue">Source</span>
                <span class="text-xs text-white/70"><b class="text-white font-bold">{s.concept}</b> &middot; <i>{s.book}</i>, {s.author}</span>
              </div>
            ))}
          </div>
        ))}
      </section>

      <!-- THE REST -->
      <section class="max-w-3xl mx-auto px-6 py-10 border-t border-white/10">
        <h2 class="text-2xl font-bold text-white mb-2">The rest of your business.</h2>
        <p class="text-white/60 mb-7 max-w-2xl">Not the three to start with, but they're in play at this stage. Here's the move on each, for when you're ready.</p>
        {data.functions.map((fn) => {
          const r = fn.departments.filter((d) => !d.start_here);
          return r.length ? (
            <div class="mb-6">
              <div class="text-xs font-bold tracking-[0.14em] uppercase text-brand-blue/80 mb-3">{fn.name}</div>
              {r.map((d) => (
                <div class="mb-5">
                  <div class="font-bold text-white">{d.name}</div>
                  <div class="italic text-white/50 text-sm mb-1">{d.constraint}</div>
                  {d.do_this && <p class="text-white/75 text-sm leading-relaxed max-w-2xl">{d.do_this}</p>}
                  {(d.sources ?? []).map((s) => <span class="text-xs text-white/40 italic mr-2">{s.concept} &middot; {s.book}.</span>)}
                </div>
              ))}
            </div>
          ) : null;
        })}
      </section>

      <!-- CTA + BUILT ON -->
      <section class="max-w-3xl mx-auto px-6 py-10 border-t border-white/10">
        {isICP ? (
          <div class="border border-brand-blue/40 bg-brand-blue/[0.08] rounded-sm p-6 md:p-8">
            <div class="text-xl font-semibold text-white mb-2">{data.cta.headline}</div>
            <p class="text-white/80 leading-relaxed mb-5 max-w-2xl">{data.cta.body}</p>
            <a href="https://calendly.com/jake-qmqx/strategy-call" target="_blank" rel="noopener" class="inline-flex items-center justify-center px-6 py-3 bg-brand-blue text-white text-base font-bold rounded-sm hover:opacity-90 transition">Book a call</a>
          </div>
        ) : (
          <div class="border border-white/15 bg-white/[0.02] rounded-sm p-6 md:p-8">
            <div class="text-xl font-semibold text-white mb-2">Want the next move sent to you?</div>
            <p class="text-white/75 leading-relaxed mb-5 max-w-2xl">{data.cta.body}</p>
            <a href="/flash" class="inline-flex items-center justify-center px-6 py-3 bg-white/10 text-white text-base font-semibold rounded-sm hover:bg-white/15 transition">Get the guide</a>
          </div>
        )}

        {builtOn.length > 0 && (
          <div class="mt-8 border-l-2 border-brand-blue bg-white/[0.03] p-5">
            <div class="text-[10px] font-bold tracking-[0.15em] uppercase text-white/50 mb-2">Built on</div>
            <div class="text-sm text-white/60 leading-relaxed">This stage draws on {builtOn.map((b, i) => (
              <span><b class="text-white/85">{b.book}</b> ({b.author}){i < builtOn.length - 1 ? (i === builtOn.length - 2 ? ', and ' : ', ') : ''}</span>
            ))}. The moves are ours. The thinking stands on theirs.</div>
          </div>
        )}

        {next && (
          <p class="mt-10 text-sm text-white/45">Next stage: <span class="text-white/70 font-medium">{next.name}</span> &middot; {next.line}</p>
        )}
        <p class="mt-4"><a href="/maturity-model" class="text-sm text-white/45 hover:text-white/80 transition">&larr; Start over</a></p>
      </section>
    </article>
  ) : (
    <section class="max-w-3xl mx-auto px-6 pt-10 pb-24">
      <div class="text-xs font-bold tracking-[0.2em] uppercase text-brand-blue mb-3">The Business Maturity Model &middot; Stage {stage.n}</div>
      <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-white leading-[1.1] mb-3">{stage.name}</h1>
      <p class="text-lg text-white/75 mb-10">The full read for this stage is being written.</p>
      {next && <p class="text-sm text-white/45">Next stage: <span class="text-white/70 font-medium">{next.name}</span></p>}
      <p class="mt-8"><a href="/maturity-model" class="text-sm text-white/45 hover:text-white/80 transition">&larr; Start over</a></p>
    </section>
  )}
</BaseLayout>
