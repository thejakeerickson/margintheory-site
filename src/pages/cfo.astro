---
import BaseLayout from '../layouts/BaseLayout.astro';

const calendlyUrl = 'https://calendly.com/jake-qmqx/strategy-call';
const SITE_URL = 'https://margintheory.co';

const serviceSchema = {
  '@type': 'Service',
  '@id': `${SITE_URL}/cfo#service`,
  name: 'Fractional CFO Services',
  serviceType: 'Fractional CFO',
  provider: { '@id': `${SITE_URL}/#organization` },
  areaServed: { '@type': 'Country', name: 'United States' },
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'Owner-operator businesses doing $1M to $20M in annual revenue',
  },
  description:
    'Monthly fractional CFO practice for owner-operator businesses doing $1M to $20M. Includes annual profit and cash targets, rolling budget, KPI dashboard, 12-month rolling cash forecast, monthly working sessions, and a 30-day action plan after every session.',
  offers: {
    '@type': 'Offer',
    price: '3000',
    priceCurrency: 'USD',
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: '3000',
      priceCurrency: 'USD',
      unitText: 'MONTH',
    },
    availability: 'https://schema.org/InStock',
    url: calendlyUrl,
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Margin Theory CFO Monthly Deliverables',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Monthly KPI scoreboard' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: '30-day action plan' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: '12-month rolling cash forecast' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Monthly CFO working session' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Between-session access' } },
    ],
  },
};

const faqSchema = {
  '@type': 'FAQPage',
  '@id': `${SITE_URL}/cfo#faq`,
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is a fractional CFO?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A CFO\'s job is to guide a business toward more profit, more cash flow, and better decisions. A fractional CFO does the same thing for businesses that do not need or cannot afford a full-time CFO at $200K+ per year. You get the strategic financial brain without the full-time salary.',
      },
    },
    {
      '@type': 'Question',
      name: 'Who is Margin Theory for?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Owner-operator businesses doing $1M to $20M in annual revenue. Operators who have the reports but do not know what to do with them, whose growth has not translated to profit, and who are making five- and six-figure decisions alone.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does Margin Theory cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Flat $3,000 per month. No contract, cancel anytime, no setup fee, no hourly billing. Roughly 20% the cost of a full-time CFO.',
      },
    },
    {
      '@type': 'Question',
      name: 'How is a fractional CFO different from a bookkeeper or a CPA?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Your bookkeeper records what happened. Your CPA files the return. A CFO looks forward with you, builds the forecast, and tells you what to do about the numbers. Margin Theory does the third job, not the first two.',
      },
    },
    {
      '@type': 'Question',
      name: 'What do the first 30 days look like?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A financial assessment, annual profit and cash targets, a rolling budget, a KPI dashboard tied to the 3 to 5 numbers that move your business, a 12-month rolling cash forecast, and at least 3 dollar-sized opportunities you can act on this quarter.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the guarantee?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'If Margin Theory does not find at least 3 specific ways to improve your profit or cash in the first 90 days, we work the next month free. Client must attend monthly sessions, be transparent about the business, and follow through on commitments.',
      },
    },
    {
      '@type': 'Question',
      name: 'Where is Margin Theory based?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Austin, Texas. Margin Theory is operated by JJE Strategy LLC. Services are delivered remotely to clients across the United States.',
      },
    },
  ],
};
---
<BaseLayout
  title="Fractional CFO Services for $1M to $20M Owner-Operators | Margin Theory"
  description="Margin Theory is a $3,000/month fractional CFO practice for owner-operator businesses doing $1M to $20M. Monthly KPI scoreboard, 30-day action plans, 12-month rolling cash forecast, and between-session access. Flat fee. No hourly billing."
  extraSchemas={[serviceSchema, faqSchema]}
>
  <!-- Hero -->
  <section>
    <div class="max-w-6xl mx-auto px-6 pt-24 pb-20 md:pt-32 md:pb-28">
      <div class="max-w-3xl">
        <div class="text-xs uppercase tracking-widest text-margin-blue font-semibold mb-6">CFO Services</div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.05] mb-6">
          Your CPA files taxes. Your bookkeeper records last month.
          <span class="block text-margin-blue mt-4">Who is looking forward with you?</span>
        </h1>
        <p class="text-lg md:text-xl text-white/80 mb-8 leading-relaxed">
          Get a fractional CFO who traces the money five drivers down, finds what's hiding in your own business, and builds the financial operating system that lets you see further. All for one flat monthly fee.
        </p>
        <a
          href={calendlyUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center px-6 py-3 bg-margin-blue text-white font-semibold rounded-md hover:opacity-90 transition"
        >
          Schedule a Strategy Call
        </a>
      </div>
    </div>
  </section>

  <!-- Does This Sound Like You? -->
  <section class="border-t border-white/10 bg-white/[0.02]">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <div class="text-xs uppercase tracking-widest text-margin-blue font-semibold mb-4">The problem</div>
          <h2 class="text-4xl font-bold tracking-tight mb-8">Does this sound like you?</h2>
          <div class="space-y-6 text-lg text-white/80 leading-relaxed">
            <div class="flex gap-4">
              <span class="text-margin-blue text-2xl leading-none mt-1">·</span>
              <p><span class="text-white font-semibold">You see what happened but you can not see what is coming.</span> You have the reports and you do not know what to do with them. Your accountant sends financials months late, and by then the money already leaked.</p>
            </div>
            <div class="flex gap-4">
              <span class="text-margin-blue text-2xl leading-none mt-1">·</span>
              <p><span class="text-white font-semibold">Growth was supposed to fix the money problem. It did not.</span> The business is doing more than ever and you are still not keeping what it should be producing. You need to grow to hire, but you need to hire to grow.</p>
            </div>
            <div class="flex gap-4">
              <span class="text-margin-blue text-2xl leading-none mt-1">·</span>
              <p><span class="text-white font-semibold">You are making decisions worth tens of thousands of dollars alone.</span> Should you hire? Should you raise prices? Should you expand? There is nothing in front of you to tell you if it is the right move.</p>
            </div>
            <div class="flex gap-4">
              <span class="text-margin-blue text-2xl leading-none mt-1">·</span>
              <p><span class="text-white font-semibold">You know the business has more in it.</span> You just can not see where the money is hiding or what lever to pull next.</p>
            </div>
          </div>
        </div>
        <div class="flex items-center">
          <div class="p-8 border border-margin-blue/30 rounded-xl bg-margin-blue/[0.03] w-full">
            <div class="text-2xl font-bold mb-4 text-white">The business owner's trap:</div>
            <p class="text-white/70 leading-relaxed mb-4">
              You're an expert at your craft. You're not an expert at running the financial side of a business. Nobody taught you that part.
            </p>
            <p class="text-white/70 leading-relaxed mb-4">
              So six figures hides in your P&L every year, one layer below where anyone is looking. In the COGS detail. In the cash-vs-accrual gap. In the timing of payroll and AR.
            </p>
            <p class="text-margin-blue font-semibold text-lg">
              That's the margin. And most operators never find it.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What's a Fractional CFO? -->
  <section class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-xs uppercase tracking-widest text-margin-blue font-semibold mb-4">The solution</div>
          <h2 class="text-4xl font-bold tracking-tight mb-6">What's a fractional CFO?</h2>
          <div class="space-y-4 text-lg text-white/80 leading-relaxed">
            <p>
              A CFO's job is to guide a business toward more profit, more cash flow, and better decisions. A fractional CFO does the same thing, but for businesses that do not need or can not afford a full-time hire at $200K+ per year.
            </p>
            <p>
              You get the strategic financial brain without the full-time salary. Monthly working sessions. A live forecast. A KPI dashboard that actually means something. And a 30-day action plan after every session.
            </p>
            <p class="text-white font-semibold">
              One flat fee per month with no hourly billing and no surprises.
            </p>
          </div>
        </div>
        <div class="space-y-4">
          <div class="p-6 border border-white/10 rounded-xl">
            <div class="text-margin-blue font-bold text-sm uppercase tracking-wider mb-2">Not a bookkeeper</div>
            <p class="text-white/70 text-sm leading-relaxed">Your bookkeeper records what happened. Your CFO tells you what to do about it.</p>
          </div>
          <div class="p-6 border border-white/10 rounded-xl">
            <div class="text-margin-blue font-bold text-sm uppercase tracking-wider mb-2">Not a tax accountant</div>
            <p class="text-white/70 text-sm leading-relaxed">Your CPA files the return. Your CFO makes sure the numbers on that return are as good as they can be.</p>
          </div>
          <div class="p-6 border border-white/10 rounded-xl">
            <div class="text-margin-blue font-bold text-sm uppercase tracking-wider mb-2">Not a business coach</div>
            <p class="text-white/70 text-sm leading-relaxed">A coach gives you frameworks. Your CFO gives you the actual numbers and tells you exactly where the money is.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Your CFO Will Do -->
  <section class="border-t border-white/10 bg-white/[0.02]">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="text-xs uppercase tracking-widest text-margin-blue font-semibold mb-4">The deliverables</div>
      <h2 class="text-4xl font-bold tracking-tight mb-4">What your CFO will do for you.</h2>
      <p class="text-lg text-white/60 mb-12 max-w-3xl">Every month, you get three things that transform how you operate.</p>

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <div class="p-8 border border-white/10 rounded-xl">
          <div class="text-margin-blue text-4xl font-bold mb-4">01</div>
          <h3 class="text-xl font-bold mb-3">A Scoreboard</h3>
          <p class="text-white/70 leading-relaxed">
            Track your profit and cash flow every month. See the 3 to 5 KPIs that actually move your business. Know exactly where you stand, updated weekly.
          </p>
        </div>
        <div class="p-8 border border-white/10 rounded-xl">
          <div class="text-margin-blue text-4xl font-bold mb-4">02</div>
          <h3 class="text-xl font-bold mb-3">An Action Plan</h3>
          <p class="text-white/70 leading-relaxed">
            After every monthly session, you leave with a prioritized 30-day action plan. What to do, in what order, with dollar amounts attached to each move.
          </p>
        </div>
        <div class="p-8 border border-white/10 rounded-xl">
          <div class="text-margin-blue text-4xl font-bold mb-4">03</div>
          <h3 class="text-xl font-bold mb-3">A Financial Guide</h3>
          <p class="text-white/70 leading-relaxed">
            Between calls, you have a CFO in your corner. When an urgent decision hits, we model it in the forecast within 24 hours and come back with a recommendation.
          </p>
        </div>
      </div>

      <div class="text-center">
        <a
          href={calendlyUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center px-6 py-3 bg-margin-blue text-white font-semibold rounded-md hover:opacity-90 transition"
        >
          Schedule a Strategy Call
        </a>
      </div>
    </div>
  </section>

  <!-- What Makes Us Different -->
  <section class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <div class="text-xs uppercase tracking-widest text-margin-blue font-semibold mb-4">The difference</div>
          <h2 class="text-4xl font-bold tracking-tight mb-8">What makes Margin Theory different.</h2>
          <div class="space-y-8 text-lg text-white/80 leading-relaxed">
            <div>
              <h3 class="text-white font-bold text-xl mb-2">We go five drivers down.</h3>
              <p>
                Most fractional CFOs stop at "COGS is too high" or "labor is creeping up." Margin Theory keeps going. Which line? Which SKU? Which shift? Which person? That's where the real money is.
              </p>
            </div>
            <div>
              <h3 class="text-white font-bold text-xl mb-2">We understand the whole machine.</h3>
              <p>
                Unlike an accountant who sees the financials, or a coach who sees the strategy, we see both. We connect the operational decisions to their financial impact in real time.
              </p>
            </div>
            <div>
              <h3 class="text-white font-bold text-xl mb-2">Flat fee. No hourly billing.</h3>
              <p>
                You should never hesitate to call your CFO because a clock is running. One flat monthly fee. Use us as much as you need.
              </p>
            </div>
          </div>
        </div>
        <div class="flex items-center">
          <div class="p-8 border-l-2 border-margin-blue bg-white/[0.02] rounded-r-xl w-full">
            <p class="text-xl text-white font-semibold leading-relaxed mb-4">
              "Just having a better understanding of the numbers boosts confidence."
            </p>
            <p class="text-white/50 mb-6">Andrew Rincon, CraigO's Lakeway</p>
            <div class="w-16 h-px bg-margin-blue/40 my-4"></div>
            <p class="text-white/60 leading-relaxed text-sm">
              Met monthly, tracked the numbers, and went from losing money to 13.3% profit in one year.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Proof / Customer Wins -->
  <section class="border-t border-white/10 bg-white/[0.02]">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="text-xs uppercase tracking-widest text-margin-blue font-semibold mb-4">Proof</div>
      <h2 class="text-4xl font-bold tracking-tight mb-12">Real operators. Real results.</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="p-8 border border-white/10 rounded-xl">
          <div class="text-margin-blue text-3xl font-bold mb-1">+$2.05M</div>
          <div class="text-white/50 text-sm mb-4">revenue growth in one year</div>
          <p class="text-white/70 leading-relaxed mb-4">
            Monthly reviews and clear targets. Revenue grew $2M in one year.
          </p>
          <div class="text-sm text-white/40">The Guest House Austin</div>
        </div>
        <div class="p-8 border border-white/10 rounded-xl">
          <div class="text-margin-blue text-3xl font-bold mb-1">+16.3%</div>
          <div class="text-white/50 text-sm mb-4">profit improvement</div>
          <p class="text-white/70 leading-relaxed mb-4">
            Went from losing money to 13.3% profit in one year through monthly sessions and clear targets.
          </p>
          <div class="text-sm text-white/40">CraigO's Lakeway</div>
        </div>
        <div class="p-8 border border-white/10 rounded-xl">
          <div class="text-margin-blue text-3xl font-bold mb-1">-$528K</div>
          <div class="text-white/50 text-sm mb-4">costs reduced in three quarters</div>
          <p class="text-white/70 leading-relaxed mb-4">
            Tracked labor every month and held the line. Costs dropped $528K in three quarters.
          </p>
          <div class="text-sm text-white/40">Guest House Las Vegas</div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Process -->
  <section class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="text-xs uppercase tracking-widest text-margin-blue font-semibold mb-4">How it works</div>
      <h2 class="text-4xl font-bold tracking-tight mb-4">Two phases. One clear path.</h2>
      <p class="text-lg text-white/60 mb-12 max-w-3xl">
        Phase 1 makes the machine visible. Phase 2 reads the machine together, every month, and finds the money hiding five drivers down.
      </p>

      <div class="mb-16">
        <h3 class="text-2xl font-bold mb-8 flex items-center gap-3">
          <span class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-margin-blue text-margin-blue text-sm font-bold">P1</span>
          First 30 Days: Visibility and Targets
        </h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="p-6 border border-white/10 rounded-xl">
            <h4 class="text-lg font-bold mb-2">Financial Assessment</h4>
            <p class="text-white/70 text-sm leading-relaxed">Books, P&L, balance sheet, cash position, AR, AP, payroll timing. We find where the business is right now and which drivers are moving the numbers.</p>
          </div>
          <div class="p-6 border border-white/10 rounded-xl">
            <h4 class="text-lg font-bold mb-2">Annual Profit & Cash Targets</h4>
            <p class="text-white/70 text-sm leading-relaxed">Clear targets set in the first 30 days so you know what winning looks like. Grounded in actual operating economics, not wishful thinking.</p>
          </div>
          <div class="p-6 border border-white/10 rounded-xl">
            <h4 class="text-lg font-bold mb-2">Annual Rolling Budget</h4>
            <p class="text-white/70 text-sm leading-relaxed">A budget built around your business so every dollar has a plan.</p>
          </div>
          <div class="p-6 border border-white/10 rounded-xl">
            <h4 class="text-lg font-bold mb-2">KPI Dashboard</h4>
            <p class="text-white/70 text-sm leading-relaxed">A simple monthly scoreboard tied to the 3 to 5 numbers that actually move the business.</p>
          </div>
          <div class="p-6 border border-white/10 rounded-xl">
            <h4 class="text-lg font-bold mb-2">12-Month Rolling Cash Forecast</h4>
            <p class="text-white/70 text-sm leading-relaxed">Week-by-week cash position for the next 12 months, updated monthly. Tight weeks and cushion weeks, color coded.</p>
          </div>
          <div class="p-6 border border-white/10 rounded-xl">
            <h4 class="text-lg font-bold mb-2">3 Opportunities, Dollar-Sized</h4>
            <p class="text-white/70 text-sm leading-relaxed">At least three specific ways to improve financial performance, each with an estimated dollar impact you can act on this quarter.</p>
          </div>
        </div>
      </div>

      <div>
        <h3 class="text-2xl font-bold mb-8 flex items-center gap-3">
          <span class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-margin-blue text-margin-blue text-sm font-bold">P2</span>
          Every Month After: Decision Discipline
        </h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="p-6 border border-white/10 rounded-xl">
            <h4 class="text-lg font-bold mb-2">Monthly CFO Working Session</h4>
            <p class="text-white/70 text-sm leading-relaxed">Review actuals vs. targets, identify the month's main constraint, and build a 30-day action plan with owners and deadlines.</p>
          </div>
          <div class="p-6 border border-white/10 rounded-xl">
            <h4 class="text-lg font-bold mb-2">Cash Flow Planning</h4>
            <p class="text-white/70 text-sm leading-relaxed">We plan cash month by month so payroll Friday is never a surprise.</p>
          </div>
          <div class="p-6 border border-white/10 rounded-xl">
            <h4 class="text-lg font-bold mb-2">Main Constraint Identification</h4>
            <p class="text-white/70 text-sm leading-relaxed">Every month we find the one thing holding your profit or cash back.</p>
          </div>
          <div class="p-6 border border-white/10 rounded-xl">
            <h4 class="text-lg font-bold mb-2">Hiring & Pricing Support</h4>
            <p class="text-white/70 text-sm leading-relaxed">Before you hire or change what you charge, we model the financial impact so you move with confidence.</p>
          </div>
          <div class="p-6 border border-white/10 rounded-xl">
            <h4 class="text-lg font-bold mb-2">Overhead Reduction Planning</h4>
            <p class="text-white/70 text-sm leading-relaxed">We find what you are spending that is not earning its keep and build a plan to cut it.</p>
          </div>
          <div class="p-6 border border-white/10 rounded-xl">
            <h4 class="text-lg font-bold mb-2">Between-Session Access</h4>
            <p class="text-white/70 text-sm leading-relaxed">Direct access to Jake when hiring, pricing, or spending decisions come up between calls.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="border-t border-white/10 bg-white/[0.02]">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="max-w-3xl mx-auto text-center">
        <div class="text-xs uppercase tracking-widest text-margin-blue font-semibold mb-4">Investment</div>
        <h2 class="text-4xl font-bold tracking-tight mb-6">Strategic CFO Advisory</h2>
        <p class="text-lg text-white/70 leading-relaxed mb-10">
          Get long-range visibility into cash, 5 to 15 points of margin improvement across pricing, costs, and revenue, and a partner that pressure-tests every major move before you make it. All without adding headcount.
        </p>
        <div class="p-10 border border-margin-blue/30 rounded-2xl bg-margin-blue/[0.03] mb-8">
          <div class="text-5xl md:text-6xl font-bold text-margin-blue mb-2">$3,000</div>
          <div class="text-xl text-white/60 mb-6">per month</div>
          <div class="flex flex-col sm:flex-row gap-4 justify-center text-white/70 text-sm mb-8">
            <span class="flex items-center gap-2"><span class="text-margin-blue">+</span> No contract</span>
            <span class="flex items-center gap-2"><span class="text-margin-blue">+</span> Cancel anytime</span>
            <span class="flex items-center gap-2"><span class="text-margin-blue">+</span> No setup fee</span>
          </div>
          <p class="text-white/50 text-sm">20% the cost of a full-time CFO.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Guarantee -->
  <section class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="max-w-3xl mx-auto text-center">
        <div class="text-xs uppercase tracking-widest text-margin-blue font-semibold mb-4">Our guarantee</div>
        <h2 class="text-4xl font-bold tracking-tight mb-6">The work produces results or we do not get paid.</h2>
        <p class="text-lg text-white/80 leading-relaxed mb-6">
          If we do not find at least 3 specific ways to improve your profit or cash in the first 90 days, we work the next month free.
        </p>
        <p class="text-white/50 leading-relaxed text-sm">
          To qualify, client must attend monthly sessions, be transparent about the business, and follow through on commitments.
        </p>
      </div>
    </div>
  </section>

  <!-- About / Founder -->
  <section class="border-t border-white/10 bg-white/[0.02]">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-xs uppercase tracking-widest text-margin-blue font-semibold mb-4">Your CFO</div>
          <h2 class="text-4xl font-bold tracking-tight mb-6">Jake Erickson</h2>
          <div class="space-y-4 text-lg text-white/80 leading-relaxed">
            <p>
