---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Margin Theory | Jake Erickson"
  description="Making sense of business and life, and sharing everything in between. Newsletter, podcast, and the fractional CFO practice that proves it works."
>
  <!-- Hero -->
  <section>
    <div class="max-w-6xl mx-auto px-6 pt-24 pb-28 md:pt-32 md:pb-40">
      <div class="flex flex-col md:flex-row md:items-center gap-12 md:gap-20">
        <div class="max-w-xl">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1] mb-8">
            The data is everywhere.
            <span class="block text-white/60 mt-3">You just haven't connected it yet.</span>
          </h1>
          <div class="mb-8">
            <div class="text-2xl font-bold mb-2">Jake Erickson</div>
            <p class="text-lg text-white/60">Making sense of business and life, and sharing everything in between.</p>
          </div>
          <a
            href="https://newsletter.margintheory.co"
            class="inline-flex items-center justify-center px-6 py-3 bg-margin-blue text-white font-semibold rounded-md hover:opacity-90 transition"
          >
            Read the newsletter
          </a>
        </div>
        <div class="flex-shrink-0">
          <img
            src="/Jake.png"
            alt="Jake Erickson"
            class="w-64 h-64 md:w-80 md:h-80 lg:w-96 lg:h-96 rounded-2xl object-cover border border-white/10"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- About Jake -->
  <section class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-6 py-20 md:py-28">
      <div class="max-w-3xl">
        <div class="text-xs uppercase tracking-widest text-margin-blue font-semibold mb-4">About</div>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-8">Who is Jake Erickson?</h2>
        <div class="space-y-6 text-lg text-white/80 leading-relaxed">
          <p>
            I run a fractional CFO practice for owner-operator businesses doing $1M to $20M. I go 5 to 10 drivers deep into the numbers most people never look at. That's where the six-figure opportunities live.
          </p>
          <p>
            But Margin Theory is bigger than the CFO work. It's the philosophy underneath. Every business and every life is producing data. In your revenue, your habits, your relationships, your decisions. Most people never connect it. I write about what happens when you do.
          </p>
        </div>
        <div class="flex gap-6 mt-8">
          <a href="https://linkedin.com/in/jakeerickson" target="_blank" rel="noopener" class="text-sm text-white/50 hover:text-white transition-colors">LinkedIn</a>
          <a href="https://instagram.com/margintheory" target="_blank" rel="noopener" class="text-sm text-white/50 hover:text-white transition-colors">Instagram</a>
          <a href="https://youtube.com/@thejakeerickson" target="_blank" rel="noopener" class="text-sm text-white/50 hover:text-white transition-colors">YouTube</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-6 py-20 md:py-28 text-center">
      <h2 class="text-4xl md:text-6xl font-bold tracking-tight mb-6">
        The data is everywhere.
        <span class="block text-margin-blue">Start connecting it.</span>
      </h2>
      <p class="text-xl text-white/70 max-w-2xl mx-auto mb-10">
        Two emails a month. Business, life, and everything in between.
      </p>
      <a
        href="https://newsletter.margintheory.co"
        class="inline-flex items-center justify-center px-8 py-4 bg-margin-blue text-white text-lg font-semibold rounded-md hover:opacity-90 transition"
      >
        Subscribe
      </a>
    </div>
  </section>
</BaseLayout>
