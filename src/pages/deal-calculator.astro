---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Deal Calculator | Margin Theory"
  description="Quick acquisition cash flow check. Enter price, SDE, and operator pay and see whether it's a business or a job."
>
  <section>
    <div class="max-w-5xl mx-auto px-6 pt-10 md:pt-14 pb-20">
      <div class="mb-8">
        <div class="text-xs font-bold tracking-[0.15em] uppercase text-brand-blue mb-2">
          Acquisition Pipeline
        </div>
        <h1 class="text-3xl md:text-4xl font-semibold tracking-tight text-white leading-[1.15] mb-3">
          Deal Calculator
        </h1>
        <p class="text-base md:text-lg text-white/70 leading-relaxed max-w-2xl">
          Drop in the numbers from a listing. The cash has to cover four things in order: the loan, an operator,
          reinvestment, then you. Green cash flow means the deal pays you. Red means it does not.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 md:gap-10 items-start">
        <!-- INPUTS -->
        <div class="border border-white/15 bg-white/[0.02] p-6 md:p-7 rounded-sm">
          <div class="space-y-5">
            <div>
              <label for="i-name" class="block text-sm font-semibold text-white/80 mb-1.5">Business name <span class="text-white/40 font-normal">(optional)</span></label>
              <input id="i-name" type="text" placeholder="Austin pool route"
                class="w-full px-4 py-3 bg-white text-charcoal text-base rounded-sm border border-transparent focus:outline-none focus:ring-2 focus:ring-brand-blue placeholder:text-charcoal/40" />
            </div>

            <div>
              <label for="i-price" class="block text-sm font-semibold text-white/80 mb-1.5">Asking price</label>
              <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-charcoal/50 text-base pointer-events-none">$</span>
                <input id="i-price" type="text" inputmode="numeric" placeholder="900,000"
                  class="w-full pl-8 pr-4 py-3 bg-white text-charcoal text-base rounded-sm border border-transparent focus:outline-none focus:ring-2 focus:ring-brand-blue placeholder:text-charcoal/40" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-white/80 mb-1.5">Earnings basis</label>
              <div class="grid grid-cols-2 gap-2" id="basis-toggle">
                <button type="button" data-basis="sde"
                  class="basis-btn px-3 py-2.5 text-sm font-semibold rounded-sm border transition text-center">
                  SDE
                </button>
                <button type="button" data-basis="profit"
                  class="basis-btn px-3 py-2.5 text-sm font-semibold rounded-sm border transition text-center">
                  Net profit
                </button>
              </div>
            </div>

            <!-- SDE mode -->
            <div id="sde-mode">
              <label for="i-sde" class="block text-sm font-semibold text-white/80 mb-1.5">SDE (annual)</label>
              <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-charcoal/50 text-base pointer-events-none">$</span>
                <input id="i-sde" type="text" inputmode="numeric" placeholder="300,000"
                  class="w-full pl-8 pr-4 py-3 bg-white text-charcoal text-base rounded-sm border border-transparent focus:outline-none focus:ring-2 focus:ring-brand-blue placeholder:text-charcoal/40" />
              </div>
              <p class="text-xs text-white/45 mt-1.5">The listing's SDE or seller's cash flow. On BizBuySell this is the "cash flow" number.</p>
            </div>

            <!-- Net profit mode -->
            <div id="profit-mode" style="display:none;">
              <label for="i-netprofit" class="block text-sm font-semibold text-white/80 mb-1.5">Net profit (annual)</label>
              <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-charcoal/50 text-base pointer-events-none">$</span>
                <input id="i-netprofit" type="text" inputmode="numeric" placeholder="150,000"
                  class="w-full pl-8 pr-4 py-3 bg-white text-charcoal text-base rounded-sm border border-transparent focus:outline-none focus:ring-2 focus:ring-brand-blue placeholder:text-charcoal/40" />
              </div>
              <p class="text-xs text-white/45 mt-1.5 mb-3">Bottom-line profit, after the owner paid themselves. Add the items below back to rebuild SDE.</p>

              <div class="border border-white/10 rounded-sm p-3 space-y-2.5">
                <div class="text-xs font-semibold uppercase tracking-wide text-white/50">Add backs to rebuild SDE</div>
                <div>
                  <label for="i-owner-salary" class="block text-xs font-semibold text-white/60 mb-1">+ Owner's salary</label>
                  <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-charcoal/50 text-sm pointer-events-none">$</span>
                    <input id="i-owner-salary" type="text" inputmode="numeric" placeholder="90,000"
                      class="w-full pl-7 pr-3 py-2 bg-white text-charcoal text-sm rounded-sm border border-transparent focus:outline-none focus:ring-2 focus:ring-brand-blue placeholder:text-charcoal/40" />
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-2">
                  <div>
                    <label for="i-da" class="block text-xs font-semibold text-white/60 mb-1">+ Deprec. &amp; amort.</label>
                    <div class="relative">
                      <span class="absolute left-3 top-1/2 -translate-y-1/2 text-charcoal/50 text-sm pointer-events-none">$</span>
                      <input id="i-da" type="text" inputmode="numeric" placeholder="0"
                        class="w-full pl-7 pr-3 py-2 bg-white text-charcoal text-sm rounded-sm border border-transparent focus:outline-none focus:ring-2 focus:ring-brand-blue placeholder:text-charcoal/40" />
                    </div>
                  </div>
                  <div>
                    <label for="i-interest" class="block text-xs font-semibold text-white/60 mb-1">+ Interest</label>
                    <div class="relative">
                      <span class="absolute left-3 top-1/2 -translate-y-1/2 text-charcoal/50 text-sm pointer-events-none">$</span>
                      <input id="i-interest" type="text" inputmode="numeric" placeholder="0"
                        class="w-full pl-7 pr-3 py-2 bg-white text-charcoal text-sm rounded-sm border border-transparent focus:outline-none focus:ring-2 focus:ring-brand-blue placeholder:text-charcoal/40" />
                    </div>
                  </div>
                </div>
                <div class="flex items-center justify-between border-t border-white/10 pt-2.5 mt-1">
                  <span class="text-sm font-semibold text-brand-blue">= SDE (recast)</span>
                  <span class="text-base font-bold text-white" id="r-recast">$0</span>
                </div>
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-white/80 mb-1.5">Who runs it?</label>
              <div class="grid grid-cols-2 gap-2" id="role-toggle">
                <button type="button" data-role="owner"
                  class="role-btn px-3 py-2.5 text-sm font-semibold rounded-sm border transition text-center">
                  You install an operator
                </button>
                <button type="button" data-role="manager"
                  class="role-btn px-3 py-2.5 text-sm font-semibold rounded-sm border transition text-center">
                  Manager already in place
                </button>
              </div>
              <p class="text-xs text-white/45 mt-1.5" id="role-hint"></p>
            </div>

            <div id="operator-wrap">
              <label for="i-operator" class="block text-sm font-semibold text-white/80 mb-1.5">Operator pay (annual)</label>
              <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-charcoal/50 text-base pointer-events-none">$</span>
                <input id="i-operator" type="text" inputmode="numeric" placeholder="0"
                  class="w-full pl-8 pr-4 py-3 bg-white text-charcoal text-base rounded-sm border border-transparent focus:outline-none focus:ring-2 focus:ring-brand-blue placeholder:text-charcoal/40" />
              </div>
              <p class="text-xs text-white/45 mt-1.5">What you'd pay someone to run it instead of you. The rule: pay the operator first. Leave at 0 only if you'll run it yourself.</p>
            </div>

            <div>
              <label for="i-reinvest" class="block text-sm font-semibold text-white/80 mb-1.5">Reinvest in growth (annual)</label>
              <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-charcoal/50 text-base pointer-events-none">$</span>
                <input id="i-reinvest" type="text" inputmode="numeric" placeholder="0"
                  class="w-full pl-8 pr-4 py-3 bg-white text-charcoal text-base rounded-sm border border-transparent focus:outline-none focus:ring-2 focus:ring-brand-blue placeholder:text-charcoal/40" />
              </div>
              <p class="text-xs text-white/45 mt-1.5">Money back into the business each year (equipment, marketing, software). The third tier. Leave at 0 to skip.</p>
            </div>

            <details class="border-t border-white/10 pt-4 group" open>
              <summary class="cursor-pointer text-sm font-semibold text-white/70 hover:text-white select-none list-none flex items-center gap-2">
                <span class="text-brand-blue transition-transform group-open:rotate-90">&rsaquo;</span>
                Financing &amp; your bar
              </summary>

              <div class="grid grid-cols-2 gap-2 mt-4" id="fin-toggle">
                <button type="button" data-fin="sba"
                  class="fin-btn px-3 py-2 text-sm font-semibold rounded-sm border transition text-center">
                  SBA loan
                </button>
                <button type="button" data-fin="seller"
                  class="fin-btn px-3 py-2 text-sm font-semibold rounded-sm border transition text-center">
                  Seller financing
                </button>
              </div>
              <p class="text-xs text-white/45 mt-2" id="fin-hint"></p>

              <div class="grid grid-cols-2 gap-3 mt-4">
                <div>
                  <label for="i-down" class="block text-xs font-semibold text-white/60 mb-1">Down payment %</label>
                  <input id="i-down" type="text" inputmode="decimal" value="10"
                    class="w-full px-3 py-2 bg-white text-charcoal text-sm rounded-sm border border-transparent focus:outline-none focus:ring-2 focus:ring-brand-blue" />
                </div>
                <div>
                  <label for="i-rate" class="block text-xs font-semibold text-white/60 mb-1">Interest rate %</label>
                  <input id="i-rate" type="text" inputmode="decimal" value="11"
                    class="w-full px-3 py-2 bg-white text-charcoal text-sm rounded-sm border border-transparent focus:outline-none focus:ring-2 focus:ring-brand-blue" />
                </div>
                <div>
                  <label for="i-term" class="block text-xs font-semibold text-white/60 mb-1">Loan term (years)</label>
                  <input id="i-term" type="text" inputmode="decimal" value="10"
                    class="w-full px-3 py-2 bg-white text-charcoal text-sm rounded-sm border border-transparent focus:outline-none focus:ring-2 focus:ring-brand-blue" />
                </div>
                <div>
                  <label for="i-closing" class="block text-xs font-semibold text-white/60 mb-1">Closing costs %</label>
                  <input id="i-closing" type="text" inputmode="decimal" value="3"
                    class="w-full px-3 py-2 bg-white text-charcoal text-sm rounded-sm border border-transparent focus:outline-none focus:ring-2 focus:ring-brand-blue" />
                </div>
              </div>

              <div class="mt-3">
                <label for="i-floor" class="block text-xs font-semibold text-white/60 mb-1">Your profit floor (annual)</label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-charcoal/50 text-sm pointer-events-none">$</span>
                  <input id="i-floor" type="text" inputmode="numeric" value="90,000"
                    class="w-full pl-7 pr-3 py-2 bg-white text-charcoal text-sm rounded-sm border border-transparent focus:outline-none focus:ring-2 focus:ring-brand-blue" />
                </div>
                <p class="text-xs text-white/45 mt-1">The income this has to clear after debt, operator, and reinvestment. Your deal-box floor is $90K.</p>
              </div>
            </details>
          </div>
        </div>

        <!-- RESULT CARD -->
        <div class="md:sticky md:top-24">
          <div style="background-color:#1E1E1E;font-family:'Inter','Helvetica Neue',Arial,sans-serif;padding:24px 26px;border:1px solid #333333;border-radius:2px;">
            <div style="border-bottom:1px solid #2e2e2e;padding-bottom:12px;margin-bottom:16px;">
              <div style="font-size:22px;font-weight:bold;letter-spacing:1px;color:#FFFFFF;text-transform:uppercase;">The Deal Sheet</div>
              <div style="margin-top:5px;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#3271D2;">Margin Theory &middot; Quick Underwrite</div>
            </div>

            <div style="font-size:16px;font-weight:bold;text-transform:uppercase;color:#FFFFFF;margin-bottom:6px;" id="r-name">Untitled deal</div>
            <div style="font-size:12.5px;color:#9a9a9a;margin-bottom:12px;"><span style="color:#3271D2;font-weight:bold;">Owner role:</span> <span id="r-role">operator installed</span></div>

            <div style="font-size:14px;line-height:2.0;">
              <div><span style="color:#3271D2;font-weight:bold;">Price:</span> <span style="color:#ededed;" id="r-price">&mdash;</span></div>
              <div><span style="color:#3271D2;font-weight:bold;" id="r-sde-label">SDE (annual):</span> <span style="color:#ededed;" id="r-sde">&mdash;</span> <span style="font-size:11.5px;font-weight:bold;" id="r-mult-flag"></span></div>
              <div><span style="color:#3271D2;font-weight:bold;">Debt service (est.):</span> <span style="color:#8a8a8a;" id="r-debt">&mdash;</span></div>
              <div><span style="color:#3271D2;font-weight:bold;">Operator pay:</span> <span style="color:#8a8a8a;" id="r-operator">&mdash;</span></div>
              <div><span style="color:#3271D2;font-weight:bold;">Reinvest in growth:</span> <span style="color:#8a8a8a;" id="r-reinvest">&mdash;</span></div>
              <div style="margin-top:6px;padding-top:6px;border-top:1px solid #2e2e2e;"><span style="color:#3271D2;font-weight:bold;">Cash flow:</span> <span style="font-weight:bold;" id="r-cashflow">&mdash;</span></div>
              <div><span style="color:#3271D2;font-weight:bold;">Cash to close:</span> <span style="color:#ededed;" id="r-close">&mdash;</span></div>
              <div><span style="color:#3271D2;font-weight:bold;">Cash on cash:</span> <span style="font-weight:bold;" id="r-coc">&mdash;</span></div>
              <div><span style="color:#3271D2;font-weight:bold;">Payback period:</span> <span style="color:#ededed;" id="r-payback">&mdash;</span></div>
            </div>

            <!-- Verdict (deal-box scorecard) -->
            <div style="border-top:1px solid #2e2e2e;margin-top:14px;padding-top:14px;">
              <span id="r-verdict" style="display:inline-block;font-size:12px;font-weight:bold;letter-spacing:0.5px;text-transform:uppercase;padding:5px 12px;border-radius:3px;color:#9a9a9a;">&mdash;</span>
              <div id="r-verdict-note" style="margin-top:8px;font-size:12.5px;color:#9a9a9a;line-height:1.5;">Enter price and SDE to see the verdict.</div>
              <div style="margin-top:12px;font-size:12.5px;line-height:1.95;">
                <div><span id="chk-mult" style="font-weight:bold;color:#666666;">&middot;</span> <span style="color:#b0b0b0;">Multiple in the 2-5x range</span></div>
                <div><span id="chk-sde" style="font-weight:bold;color:#666666;">&middot;</span> <span style="color:#b0b0b0;">SDE clears your $270K deal-box line</span></div>
                <div><span id="chk-job" style="font-weight:bold;color:#666666;">&middot;</span> <span style="color:#b0b0b0;">Covers an operator (a business, not a job)</span></div>
                <div><span id="chk-floor" style="font-weight:bold;color:#666666;">&middot;</span> <span style="color:#b0b0b0;">Cash flow clears your $90K floor</span></div>
              </div>
            </div>

            <div style="border-top:1px solid #2e2e2e;margin-top:16px;padding-top:12px;font-size:11.5px;color:#7e7e7e;line-height:1.7;font-style:italic;">
              The four tiers: the cash covers the loan, an operator, reinvestment, then you. Two gut checks before you sign: will it pay for itself, and what happens if it does not. Payback is the cash to close divided by yearly cash flow, how fast your money comes back.
            </div>
          </div>
        </div>
      </div>

      <!-- ===== The Deal Screen (business-quality screen) ===== -->
      <div class="mt-12 border border-white/15 bg-white/[0.02] p-6 md:p-8 rounded-sm">
        <div class="text-xs font-bold tracking-[0.15em] uppercase text-brand-blue mb-2">The Deal Screen</div>
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight text-white mb-2">Is it the right kind of business?</h2>
        <p class="text-sm md:text-base text-white/70 leading-relaxed max-w-2xl mb-6">
          The math above tells you whether a deal pays. This tells you whether it is the kind of business worth owning in the first place.
          Tap what is true. A real deal is green on both, the numbers and the business.
        </p>

        <div class="grid md:grid-cols-2 gap-7">
          <!-- SOWS -->
          <div>
            <div class="text-sm font-semibold text-white/85 mb-1">Boring in the good way <span class="text-white/40 font-normal">(SOWS)</span></div>
            <p class="text-xs text-white/45 mb-3">Stale, old, weak competition, simple. The neglect is your upside.</p>
            <div class="flex flex-wrap gap-2" data-group="sows">
              <button type="button" data-trig class="trig-btn px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">Stale (behind on tech &amp; marketing)</button>
              <button type="button" data-trig class="trig-btn px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">Old (5+ years, repeat customers)</button>
              <button type="button" data-trig class="trig-btn px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">Weak competitors nearby</button>
              <button type="button" data-trig class="trig-btn px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">Simple (an 8-year-old gets it)</button>
            </div>
          </div>
          <!-- BRRT -->
          <div>
            <div class="text-sm font-semibold text-white/85 mb-1">Upside is real <span class="text-white/40 font-normal">(BRRT)</span></div>
            <p class="text-xs text-white/45 mb-3">Cash flow, recession-resistant, room to raise prices, tech to add.</p>
            <div class="flex flex-wrap gap-2" data-group="brrt">
              <button type="button" data-trig class="trig-btn px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">Recurring cash flow (not cash-suck)</button>
              <button type="button" data-trig class="trig-btn px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">Recession-resistant (a need, not a want)</button>
              <button type="button" data-trig class="trig-btn px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">Room to raise prices</button>
              <button type="button" data-trig class="trig-btn px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">Tech you can add</button>
            </div>
          </div>
        </div>

        <!-- Deal-breakers -->
        <div class="mt-7">
          <div class="text-sm font-semibold text-white/85 mb-1">Deal-breakers <span class="text-white/40 font-normal">(any one and you walk)</span></div>
          <p class="text-xs text-white/45 mb-3">The seven deadly businesses plus your can't-stands. High failure rate, lopsided risk, or it does not transfer.</p>
          <div class="flex flex-wrap gap-2" data-group="kill">
            <button type="button" data-trig class="trig-btn trig-kill px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">Restaurant, bar, or hotel</button>
            <button type="button" data-trig class="trig-btn trig-kill px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">Retail storefront (no float)</button>
            <button type="button" data-trig class="trig-btn trig-kill px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">Consulting / project shop</button>
            <button type="button" data-trig class="trig-btn trig-kill px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">Personal brand or owner is the face</button>
            <button type="button" data-trig class="trig-btn trig-kill px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">Credential-gated (owner is the licensed producer)</button>
            <button type="button" data-trig class="trig-btn trig-kill px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">One customer over 25% of revenue</button>
            <button type="button" data-trig class="trig-btn trig-kill px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">Amazon FBA / platform-dependent</button>
            <button type="button" data-trig class="trig-btn trig-kill px-3 py-2 text-xs font-semibold rounded-sm border text-left transition">Dry cleaner</button>
          </div>
        </div>

        <!-- Trigger verdict -->
        <div class="mt-7 pt-5 border-t border-white/10 flex items-center gap-4 flex-wrap">
          <span id="trig-verdict" style="display:inline-block;font-size:12px;font-weight:bold;letter-spacing:0.5px;text-transform:uppercase;padding:6px 14px;border-radius:3px;color:#9a9a9a;background:rgba(255,255,255,0.04);">Tap what is true</span>
          <span id="trig-note" class="text-sm text-white/55 leading-snug">Eight quality signals, minus any deal-breaker.</span>
        </div>
      </div>
    </div>
  </section>

  <script>
    type Role = 'owner' | 'manager';
    type Basis = 'sde' | 'profit';
    type Fin = 'sba' | 'seller';

    const $ = (id: string) => document.getElementById(id) as HTMLElement;
    const $i = (id: string) => document.getElementById(id) as HTMLInputElement;

    const GREEN = '#5cc98a';
    const RED = '#e8736b';
    const GOLD = '#F4A93C';
    const MUTED = '#9a9a9a';

    const DEALBOX_SDE_LINE = 270000; // Jake's deal-box SDE minimum

    // strip everything but digits and a single decimal point
    function parseNum(raw: string): number {
      if (!raw) return NaN;
      const cleaned = raw.replace(/[^0-9.]/g, '');
      if (cleaned === '' || cleaned === '.') return NaN;
      return parseFloat(cleaned);
    }
    const usd = (n: number) => '$' + Math.round(n).toLocaleString('en-US');

    // live comma formatting for the dollar fields (cursor stays at end)
    function formatMoneyField(el: HTMLInputElement) {
      const digits = el.value.replace(/[^0-9]/g, '');
      el.value = digits === '' ? '' : parseInt(digits, 10).toLocaleString('en-US');
    }

    // ----- role toggle -----
    let role: Role = 'owner';
    const roleBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.role-btn'));

    function paintToggle(btns: HTMLButtonElement[], attr: string, active: string) {
      btns.forEach((b) => {
        const on = b.dataset[attr] === active;
        b.style.backgroundColor = on ? '#3271D2' : 'transparent';
        b.style.borderColor = on ? '#3271D2' : 'rgba(255,255,255,0.2)';
        b.style.color = on ? '#ffffff' : 'rgba(255,255,255,0.7)';
      });
    }

    function paintRole() {
      paintToggle(roleBtns, 'role', role);
      const wrap = $('operator-wrap');
      const hint = $('role-hint');
      const opInput = $i('i-operator');
      if (role === 'manager') {
        wrap.style.opacity = '0.4';
        wrap.style.pointerEvents = 'none';
        opInput.disabled = true;
        hint.textContent = 'A manager is already in place, so their pay is already inside the SDE. No operator pay subtracted.';
      } else {
        wrap.style.opacity = '1';
        wrap.style.pointerEvents = 'auto';
        opInput.disabled = false;
        hint.textContent = 'You would install an operator. Their pay comes out of SDE.';
      }
    }

    roleBtns.forEach((b) =>
      b.addEventListener('click', () => {
        role = (b.dataset.role as Role) || 'owner';
        paintRole();
        recompute();
      })
    );

    // ----- earnings basis toggle (SDE direct, or recast from net profit) -----
    let basis: Basis = 'sde';
    const basisBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.basis-btn'));

    function paintBasis() {
      paintToggle(basisBtns, 'basis', basis);
      $('sde-mode').style.display = basis === 'sde' ? '' : 'none';
      $('profit-mode').style.display = basis === 'profit' ? '' : 'none';
    }

    basisBtns.forEach((b) =>
      b.addEventListener('click', () => {
        basis = (b.dataset.basis as Basis) || 'sde';
        paintBasis();
        recompute();
      })
    );

    // ----- financing type toggle (SBA bank loan vs seller financing) -----
    let fin: Fin = 'sba';
    const finBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.fin-btn'));
    const FIN_PRESETS: Record<Fin, { down: string; rate: string; term: string; closing: string }> = {
      sba: { down: '10', rate: '11', term: '10', closing: '3' },
      seller: { down: '15', rate: '6', term: '7', closing: '1' },
    };

    function paintFin() {
      paintToggle(finBtns, 'fin', fin);
      $('fin-hint').textContent =
        fin === 'seller'
          ? "The Profit Payback Method: the seller carries the note and the business's profits pay them back. Baseline 10-50% down, 3-10 years, rate often beats the bank, closes fast."
          : 'SBA 7(a) baseline: 10% down, ~11%, 10 years, 3% closing. Most common, but slowest to close (~90 days).';
    }

    finBtns.forEach((b) =>
      b.addEventListener('click', () => {
        fin = (b.dataset.fin as Fin) || 'sba';
        const p = FIN_PRESETS[fin];
        $i('i-down').value = p.down;
        $i('i-rate').value = p.rate;
        $i('i-term').value = p.term;
        $i('i-closing').value = p.closing;
        paintFin();
        recompute();
      })
    );

    // ----- amortization (annual debt service on the acquisition loan) -----
    function annualDebtService(price: number, downPct: number, ratePct: number, termYears: number): number {
      const loan = price * (1 - downPct / 100);
      if (loan <= 0 || termYears <= 0) return 0;
      const r = ratePct / 100 / 12;
      const n = termYears * 12;
      const monthly = r === 0 ? loan / n : (loan * r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
      return monthly * 12;
    }

    function setCheck(id: string, pass: boolean) {
      const el = $(id);
      el.textContent = pass ? '✓' : '✗';
      el.style.color = pass ? GREEN : RED;
    }

    // ----- main compute -----
    function recompute() {
      const price = parseNum($i('i-price').value);

      // SDE: entered directly, or recast from net profit + add-backs
      let sde: number;
      if (basis === 'profit') {
        const np = parseNum($i('i-netprofit').value);
        const ownerSalary = parseNum($i('i-owner-salary').value) || 0;
        const da = parseNum($i('i-da').value) || 0;
        const interestAddback = parseNum($i('i-interest').value) || 0;
        sde = isNaN(np) ? NaN : np + ownerSalary + da + interestAddback;
        $('r-recast').textContent = isNaN(np) ? '$0' : usd(sde);
      } else {
        sde = parseNum($i('i-sde').value);
      }
      $('r-sde-label').textContent = basis === 'profit' ? 'SDE (recast):' : 'SDE (annual):';

      const down = parseNum($i('i-down').value) || 0;
      const rate = parseNum($i('i-rate').value) || 0;
      const term = parseNum($i('i-term').value) || 0;
      const closing = parseNum($i('i-closing').value) || 0;
      const operatorRaw = parseNum($i('i-operator').value);
      const reinvestRaw = parseNum($i('i-reinvest').value);
      const floor = parseNum($i('i-floor').value) || 0;

      const hasPrice = !isNaN(price) && price > 0;
      const hasSDE = !isNaN(sde) && sde > 0;

      // name + owner role
      $('r-name').textContent = $i('i-name').value.trim() || 'Untitled deal';
      $('r-role').textContent = role === 'manager' ? 'manager in place' : 'operator installed';

      // price
      $('r-price').textContent = hasPrice ? usd(price) : '—';

      // SDE with multiple + 2-5x flag
      const multFlag = $('r-mult-flag');
      if (hasSDE) {
        let sdeTxt = usd(sde);
        if (hasPrice) {
          const m = price / sde;
          sdeTxt += '  ·  ' + m.toFixed(1) + 'x';
          if (m >= 2 && m <= 5) {
            multFlag.textContent = 'in 2-5x';
            multFlag.style.color = GREEN;
          } else if (m > 5) {
            multFlag.textContent = 'above 2-5x';
            multFlag.style.color = GOLD;
          } else {
            multFlag.textContent = 'under 2x, dig in';
            multFlag.style.color = GOLD;
          }
        } else {
          multFlag.textContent = '';
        }
        $('r-sde').textContent = sdeTxt;
      } else {
        $('r-sde').textContent = '—';
        multFlag.textContent = '';
      }

      // debt service
      const debt = hasPrice ? annualDebtService(price, down, rate, term) : 0;
      $('r-debt').textContent = hasPrice ? usd(debt) + '/yr' : '—';

      // operator pay
      const operatorPay = role === 'manager' ? 0 : isNaN(operatorRaw) ? 0 : operatorRaw;
      $('r-operator').textContent =
        role === 'manager' ? 'already in SDE' : isNaN(operatorRaw) ? '$0/yr' : usd(operatorPay) + '/yr';

      // reinvestment
      const reinvest = isNaN(reinvestRaw) ? 0 : reinvestRaw;
      $('r-reinvest').textContent = isNaN(reinvestRaw) ? '$0/yr' : usd(reinvest) + '/yr';

      // cash flow + cash on cash + payback (the four tiers)
      const cfEl = $('r-cashflow');
      const cocEl = $('r-coc');
      const paybackEl = $('r-payback');
      const cashToClose = hasPrice ? price * ((down + closing) / 100) : 0;
      const cf = hasSDE ? sde - debt - operatorPay - reinvest : NaN;

      if (hasSDE) {
        const positive = cf >= 0;
        const cfMo = cf / 12;
        cfEl.textContent =
          (positive ? '' : '−') + usd(Math.abs(cf)) + '/yr  (' + (positive ? '~' : '−') + usd(Math.abs(cfMo)) + '/mo)' + (positive ? '' : '  underwater');
        cfEl.style.color = positive ? GREEN : RED;

        if (cashToClose > 0) {
          const coc = (cf / cashToClose) * 100;
          const cocPos = coc >= 0;
          cocEl.textContent = (cocPos ? '~' : '−') + Math.abs(Math.round(coc)) + '%';
          cocEl.style.color = cocPos ? GREEN : RED;

          if (cf > 0) {
            const yrs = cashToClose / cf;
            paybackEl.textContent = yrs < 1 ? Math.round(yrs * 12) + ' mo' : yrs.toFixed(1) + ' yrs';
            paybackEl.style.color = '#ededed';
          } else {
            paybackEl.textContent = 'never';
            paybackEl.style.color = MUTED;
          }
        } else {
          cocEl.textContent = '—';
          cocEl.style.color = MUTED;
          paybackEl.textContent = '—';
          paybackEl.style.color = MUTED;
        }
      } else {
        cfEl.textContent = 'enter SDE';
        cfEl.style.color = MUTED;
        cocEl.textContent = '—';
        cocEl.style.color = MUTED;
        paybackEl.textContent = '—';
        paybackEl.style.color = MUTED;
      }

      $('r-close').textContent = hasPrice ? '~' + usd(cashToClose) : '—';

      // ----- verdict (scored against the deal box) -----
      const vEl = $('r-verdict');
      const nEl = $('r-verdict-note');
      if (hasSDE && hasPrice) {
        const m = price / sde;
        setCheck('chk-mult', m >= 2 && m <= 5);
        setCheck('chk-sde', sde >= DEALBOX_SDE_LINE);
        setCheck('chk-job', sde - operatorPay - reinvest > 0);
        setCheck('chk-floor', cf >= floor);

        if (cf <= 0) {
          vEl.textContent = "It's a job";
          vEl.style.color = RED;
          vEl.style.backgroundColor = 'rgba(232,115,107,0.14)';
          nEl.textContent = 'Underwater after the loan and an operator. You would be buying yourself a job, not income.';
        } else if (cf < floor) {
          vEl.textContent = 'Tight';
          vEl.style.color = GOLD;
          vEl.style.backgroundColor = 'rgba(244,169,60,0.14)';
          nEl.textContent = 'It pays you, but under your ' + usd(floor) + ' floor. Work the price or the terms to clear the bar.';
        } else {
          vEl.textContent = 'Fit';
          vEl.style.color = GREEN;
          vEl.style.backgroundColor = 'rgba(92,201,138,0.14)';
          nEl.textContent = 'Clears your ' + usd(floor) + ' floor after the loan and a real operator.';
        }
      } else {
        ['chk-mult', 'chk-sde', 'chk-job', 'chk-floor'].forEach((id) => {
          const el = $(id);
          el.textContent = '·';
          el.style.color = '#666666';
        });
        vEl.textContent = '—';
        vEl.style.color = MUTED;
        vEl.style.backgroundColor = 'transparent';
        nEl.textContent = 'Enter price and SDE to see the verdict.';
      }
    }

    // ----- wire up -----
    ['i-price', 'i-sde', 'i-operator', 'i-netprofit', 'i-owner-salary', 'i-da', 'i-interest', 'i-reinvest', 'i-floor'].forEach((id) => {
      const el = $i(id);
      el.addEventListener('input', () => {
        formatMoneyField(el);
        recompute();
      });
    });
    ['i-name', 'i-down', 'i-rate', 'i-term', 'i-closing'].forEach((id) => {
      $i(id).addEventListener('input', recompute);
    });

    paintFin();
    paintBasis();
    paintRole();
    recompute();
  </script>

  <script>
    // ----- The Deal Screen: qualitative business-quality screen -----
    const TGREEN = '#5cc98a';
    const TRED = '#e8736b';
    const TGOLD = '#F4A93C';
    const TBLUE = '#3271D2';

    const trigBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-trig]'));

    function paintTrig(btn: HTMLButtonElement, on: boolean) {
      const kill = btn.classList.contains('trig-kill');
      if (on) {
        btn.style.backgroundColor = kill ? 'rgba(232,115,107,0.16)' : 'rgba(50,113,210,0.18)';
        btn.style.borderColor = kill ? TRED : TBLUE;
        btn.style.color = '#ffffff';
      } else {
        btn.style.backgroundColor = 'transparent';
        btn.style.borderColor = 'rgba(255,255,255,0.2)';
        btn.style.color = 'rgba(255,255,255,0.7)';
      }
    }

    function scoreTriggers() {
      const onGood = document.querySelectorAll('[data-group="sows"] [data-on="1"], [data-group="brrt"] [data-on="1"]').length;
      const onKill = document.querySelectorAll('[data-group="kill"] [data-on="1"]').length;
      const vEl = document.getElementById('trig-verdict') as HTMLElement;
      const nEl = document.getElementById('trig-note') as HTMLElement;

      if (onKill > 0) {
        vEl.textContent = 'Walk away';
        vEl.style.color = TRED;
        vEl.style.background = 'rgba(232,115,107,0.14)';
        nEl.textContent = onKill + (onKill === 1 ? ' deal-breaker is' : ' deal-breakers are') + " on the deadly list. The numbers do not matter.";
        return;
      }

      let label: string, color: string, note: string;
      if (onGood >= 7) {
        label = 'Boring gold';
        color = TGREEN;
        note = 'Hits ' + onGood + ' of 8 signals and no deal-breakers. The kind of business worth owning.';
      } else if (onGood >= 4) {
        label = 'Workable, dig in';
        color = TGOLD;
        note = onGood + ' of 8 signals. Real, but find the gaps before you commit.';
      } else if (onGood >= 1) {
        label = 'Weak business';
        color = TRED;
        note = 'Only ' + onGood + ' of 8 signals. Boring-good is where the money is. This is thin.';
      } else {
        label = 'Tap what is true';
        color = '#9a9a9a';
        note = 'Eight quality signals, minus any deal-breaker.';
      }
      vEl.textContent = label;
      vEl.style.color = color;
      vEl.style.background = 'rgba(255,255,255,0.04)';
      nEl.textContent = note;
    }

    trigBtns.forEach((b) => {
      paintTrig(b, false);
      b.addEventListener('click', () => {
        const on = b.dataset.on === '1';
        b.dataset.on = on ? '0' : '1';
        paintTrig(b, !on);
        scoreTriggers();
      });
    });

    scoreTriggers();
  </script>

  <script>
    // ----- pre-fill from URL (the Deal Sheet "Screen this deal" deep-link) -----
    const qp = new URLSearchParams(window.location.search);
    if ([...qp.keys()].length > 0) {
      const setField = (id, val) => {
        const el = document.getElementById(id);
        if (el && val !== null && val !== '') {
          el.value = val;
          el.dispatchEvent(new Event('input', { bubbles: true }));
        }
      };
      setField('i-name', qp.get('name'));
      setField('i-price', qp.get('price'));
      setField('i-sde', qp.get('sde'));

      if (qp.get('role') === 'manager') {
        const mgr = document.querySelector('[data-role="manager"]');
        if (mgr) mgr.click();
      } else {
        setField('i-operator', qp.get('op'));
      }

      const tap = (group, idx) => {
        const b = document.querySelectorAll('[data-group="' + group + '"] [data-trig]')[idx];
        if (b && b.dataset.on !== '1') b.click();
      };
      const MAP = {
        sows: { stale: 0, old: 1, weak: 2, simple: 3 },
        brrt: { recurring: 0, recession: 1, raise: 2, tech: 3 },
        kill: { restaurant: 0, retail: 1, consulting: 2, personalbrand: 3, credential: 4, concentration: 5, fba: 6, drycleaner: 7 },
      };
      Object.keys(MAP).forEach((group) => {
        Object.keys(MAP[group]).forEach((k) => {
          if (qp.get(k) === '1') tap(group, MAP[group][k]);
        });
      });
    }
  </script>
</BaseLayout>
