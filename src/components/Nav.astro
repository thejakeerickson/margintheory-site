---
const nav = [
  { href: 'https://newsletter.margintheory.co', label: 'Newsletter' },
  { href: '/series', label: 'Podcast' },
  { href: '/about', label: 'About' },
  { href: '/cfo', label: 'Work With Me' },
];
---
<header class="sticky top-0 z-50 bg-charcoal/95 backdrop-blur border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-bold text-xl tracking-tight text-white">
      Margin Theory
    </a>
    <nav class="hidden md:flex items-center gap-8">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-sm text-white/80 hover:text-white transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
  <nav class="md:hidden px-6 pb-4 pt-1 flex flex-wrap gap-x-5 gap-y-2 text-sm text-white/80">
    {nav.map((item) => (
      <a href={item.href} class="hover:text-white">{item.label}</a>
    ))}
  </nav>
</header>
