---
const year = new Date().getFullYear();
---
<footer class="border-t border-white/10 mt-24">
  <div class="max-w-6xl mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-3 gap-10">
    <div>
      <div class="font-bold text-xl mb-3">Edge Theory</div>
      <p class="text-sm text-white/60 max-w-xs leading-relaxed">
        A media brand and financial operating system for owner-operator businesses doing $1M to $20M.
      </p>
    </div>
    <div>
      <div class="text-sm font-semibold text-white/90 mb-3 uppercase tracking-wider">Explore</div>
      <ul class="space-y-2 text-sm text-white/60">
        <li><a href="/newsletter" class="hover:text-white transition-colors">Newsletter</a></li>
        <li><a href="/podcast" class="hover:text-white transition-colors">Podcast</a></li>
        <li><a href="/cfo" class="hover:text-white transition-colors">CFO Services</a></li>
        <li><a href="/about" class="hover:text-white transition-colors">About</a></li>
      </ul>
    </div>
    <div>
      <div class="text-sm font-semibold text-white/90 mb-3 uppercase tracking-wider">Contact</div>
      <ul class="space-y-2 text-sm text-white/60">
        <li><a href="mailto:jake@edgetheory.co" class="hover:text-white transition-colors">jake@edgetheory.co</a></li>
        <li>
          <a
            href="https://calendly.com/jake-qmqx/right-fit-call"
            target="_blank"
            rel="noopener"
            class="hover:text-white transition-colors"
          >
            Book a Right Fit Call
          </a>
        </li>
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-6 py-6 text-xs text-white/40 flex flex-col md:flex-row justify-between gap-2">
      <div>© {year} Edge Theory. Operated by JJE Strategy LLC.</div>
      <div>Not investment, tax, or legal advice.</div>
    </div>
  </div>
</footer>
